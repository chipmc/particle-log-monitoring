function parseOptions(args) {
  const options = {
    stackName: process.env.TELEMETRY_STACK_NAME || DEFAULT_STACK_NAME,
    projectId: process.env.TELEMETRY_PROJECT_ID || DEFAULT_PROJECT_ID,
    json: false,
    hours: DEFAULT_TIMELINE_HOURS,
    limit: DEFAULT_TIMELINE_LIMIT,
    intervalSeconds: DEFAULT_WATCH_INTERVAL_SECONDS,
    sinceMs: 0,
    includeTypes: null,
    excludeTypes: new Set(),
    serialOnly: false,
    raw: false,
    awsProfile: process.env.AWS_PROFILE,
    awsRegion: process.env.AWS_REGION || process.env.AWS_DEFAULT_REGION,
    positionals: [],
  };

  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];
    if (arg === '--json') {
      options.json = true;
    } else if (arg === '--stack') {
      options.stackName = requireOptionValue(args, ++index, '--stack');
    } else if (arg === '--project-id') {
      options.projectId = requireOptionValue(args, ++index, '--project-id');
    } else if (arg === '--profile') {
      options.awsProfile = requireOptionValue(args, ++index, '--profile');
    } else if (arg === '--region') {
      options.awsRegion = requireOptionValue(args, ++index, '--region');
    } else if (arg === '--hours') {
      options.hours = parsePositiveInteger(requireOptionValue(args, ++index, '--hours'), '--hours');
    } else if (arg === '--limit') {
      options.limit = parsePositiveInteger(requireOptionValue(args, ++index, '--limit'), '--limit');
    } else if (arg === '--interval') {
      options.intervalSeconds = parseWatchInterval(requireOptionValue(args, ++index, '--interval'));
    } else if (arg === '--since') {
      options.sinceMs = parseDurationMs(requireOptionValue(args, ++index, '--since'), '--since');
    } else if (arg === '--types') {
      options.includeTypes = parseCategorySet(requireOptionValue(args, ++index, '--types'), '--types');
    } else if (arg === '--exclude') {
      options.excludeTypes = parseCategorySet(requireOptionValue(args, ++index, '--exclude'), '--exclude');
    } else if (arg === '--serial-only') {
      options.serialOnly = true;
      options.includeTypes = new Set(['SERIAL']);
    } else if (arg === '--raw' || arg === '--full') {
      options.raw = true;
    } else if (arg.startsWith('--')) {
      fail(`Unknown option: ${arg}`);
    } else {
      options.positionals.push(arg);
    }
  }

  return options;
}

function requireOptionValue(args, index, option) {
  const value = args[index];
  if (!value || value.startsWith('--')) fail(`${option} requires a value.`);
  return value;
}

function parsePositiveInteger(value, option) {
  const parsed = Number(value);
  if (!Number.isInteger(parsed) || parsed <= 0) fail(`${option} must be a positive integer.`);
  return parsed;
}

function parseWatchInterval(value) {
  const parsed = Number(value);
  if (!Number.isFinite(parsed) || parsed < 1) fail('--interval must be at least 1 second.');
  return parsed;
}

function parseDurationMs(value, option) {
  const match = String(value).trim().match(/^(\d+(?:\.\d+)?)(s|m|h)?$/i);
  if (!match) fail(`${option} must be a duration such as 30s, 5m, or 1h.`);

  const amount = Number(match[1]);
  const unit = (match[2] || 's').toLowerCase();
  const multiplier = unit === 'h' ? 60 * 60 * 1000 : unit === 'm' ? 60 * 1000 : 1000;
  return Math.max(0, Math.floor(amount * multiplier));
}

function formatDuration(ms) {
  if (ms % (60 * 60 * 1000) === 0) return `${ms / (60 * 60 * 1000)}h`;
  if (ms % (60 * 1000) === 0) return `${ms / (60 * 1000)}m`;
  if (ms % 1000 === 0) return `${ms / 1000}s`;
  return `${ms}ms`;
}

function parseCategorySet(value, option) {
  const categories = new Set(String(value).split(',').map(entry => entry.trim().toUpperCase()).filter(Boolean));
  if (categories.size === 0) fail(`${option} must include at least one category.`);
  return categories;
}

function ensureNoSelector(positionals, command) {
  if (positionals.length > 0) fail(`${command} does not accept a selector.`);
}

function requireSelector(positionals, command) {
  if (positionals.length !== 1) fail(`${command} requires exactly one device name or device id.`);
  return positionals[0];
}

async function loadContext(options) {
  const stack = awsJson(options, ['cloudformation', 'describe-stacks', '--stack-name', options.stackName], {
    notFoundMessage: `CloudFormation stack not found: ${options.stackName}`,
  });
  const stackDescription = stack.Stacks && stack.Stacks[0];
  if (!stackDescription) fail(`CloudFormation stack not found: ${options.stackName}`);

  const outputs = Object.fromEntries((stackDescription.Outputs || []).map(output => [output.OutputKey, output.OutputValue]));
  const deviceCurrentStateTableName = outputs.DeviceCurrentStateTableName;
  const logEventsTableName = outputs.LogEventsTableName;
  const queryApiBaseUrl = outputs.QueryApiBaseUrl;
  if (!deviceCurrentStateTableName) fail('Stack output DeviceCurrentStateTableName was not found.');
  if (!logEventsTableName) fail('Stack output LogEventsTableName was not found.');
  if (!queryApiBaseUrl) fail('Stack output QueryApiBaseUrl was not found.');

  const resources = awsJson(options, ['cloudformation', 'describe-stack-resources', '--stack-name', options.stackName]);
  const lambdaResource = (resources.StackResources || []).find(resource => resource.ResourceType === 'AWS::Lambda::Function');
  if (!lambdaResource || !lambdaResource.PhysicalResourceId) {
    fail('Could not discover telemetry Lambda function from the CloudFormation stack.');
  }

  const lambdaConfig = awsJson(options, ['lambda', 'get-function-configuration', '--function-name', lambdaResource.PhysicalResourceId]);
  const lambdaEnv = (lambdaConfig.Environment && lambdaConfig.Environment.Variables) || {};

  return {
    options,
    deviceCurrentStateTableName,
    logEventsTableName,
    queryApiBaseUrl: queryApiBaseUrl.replace(/\/+$/, ''),
    webhookSecret: lambdaEnv.PARTICLE_WEBHOOK_SECRET || '',
    particleAccessToken: lambdaEnv.PARTICLE_ACCESS_TOKEN || '',
    particleApiBaseUrl: (lambdaEnv.PARTICLE_API_BASE_URL || 'https://api.particle.io').replace(/\/+$/, ''),
    nameCache: new Map(),
  };
}

async function loadDevices(context) {
  const devices = [];
  let exclusiveStartKey;

  do {
    const args = [
      'dynamodb', 'scan',
      '--table-name', context.deviceCurrentStateTableName,
      '--filter-expression', 'projectId = :projectId',
      '--expression-attribute-values', JSON.stringify({ ':projectId': { S: context.options.projectId } }),
    ];
    if (exclusiveStartKey) {
      args.push('--exclusive-start-key', JSON.stringify(exclusiveStartKey));
    }

    const page = awsJson(context.options, args);
    for (const item of page.Items || []) {
      devices.push(unmarshall(item));
    }
    exclusiveStartKey = page.LastEvaluatedKey;
  } while (exclusiveStartKey);

  devices.sort((left, right) => compareIso(right.lastEventTime, left.lastEventTime));
  return devices;
}

async function loadDeviceInventory(context) {
  const devices = await loadDevices(context);
  await enrichDeviceNames(context, devices, { required: false });
  return devices;
}

async function enrichDeviceNames(context, devices, { required }) {
  const missing = devices.filter(device => !stringValue(device.deviceName));
  if (missing.length === 0) return;

  if (!context.particleAccessToken) {
    if (required) {
      fail('Device-name lookup requires PARTICLE_ACCESS_TOKEN in the deployed Lambda environment, but it is missing. Use a full device ID or configure the token.');
    }
    return;
  }

  await Promise.all(missing.map(async (device) => {
    const resolved = await resolveParticleDeviceName(context, device.deviceId);
    if (resolved) device.deviceName = resolved;
  }));
}

async function resolveParticleDeviceName(context, deviceId) {
  if (context.nameCache.has(deviceId)) return context.nameCache.get(deviceId);

  const response = await fetch(`${context.particleApiBaseUrl}/v1/devices/${encodeURIComponent(deviceId)}`, {
    headers: {
      Authorization: `Bearer ${context.particleAccessToken}`,
      Accept: 'application/json',
    },
  });

  if (!response.ok) {
    context.nameCache.set(deviceId, null);
    return null;
  }

  const payload = await response.json();
  const name = typeof payload.name === 'string' && payload.name.trim() ? payload.name.trim() : null;
  context.nameCache.set(deviceId, name);
  return name;
}

function resolveDeviceSelector(devices, selector, context = undefined) {
  if (isDeviceId(selector)) {
    const byId = devices.find(device => device.deviceId === selector);
    if (!byId) fail(`Device selector not found: ${selector}`);
    return byId;
  }

  const normalizedSelector = selector.toLowerCase();
  const exact = devices.filter(device => stringValue(device.deviceName).toLowerCase() === normalizedSelector);
  if (exact.length === 1) return exact[0];
  if (exact.length > 1) failAmbiguous(selector, exact);

  const partial = devices.filter(device => stringValue(device.deviceName).toLowerCase().includes(normalizedSelector));
  if (partial.length === 1) return partial[0];
  if (partial.length > 1) failAmbiguous(selector, partial);

  if (context && devices.some(device => !stringValue(device.deviceName)) && !context.particleAccessToken) {
    fail('Device-name lookup requires PARTICLE_ACCESS_TOKEN in the deployed Lambda environment, but it is missing. Use a full device ID or configure the token.');
  }

  fail(`Device selector not found: ${selector}`);
}

async function fetchTimeline(context, deviceId, options) {
  if (!context.webhookSecret) return queryTimelineFromDynamo(context, deviceId, options);

  const params = new URLSearchParams({
    hours: String(options.hours),
    limit: String(options.limit),
  });
  const url = `${context.queryApiBaseUrl}/${encodeURIComponent(deviceId)}/timeline?${params.toString()}`;
  const response = await fetch(url, {
    headers: {
      'x-particle-webhook-secret': context.webhookSecret,
      Accept: 'application/json',
    },
  });
  const text = await response.text();
  let payload;
  try {
    payload = text ? JSON.parse(text) : {};
  } catch {
    fail(`Timeline API returned non-JSON response with HTTP ${response.status}.`);
  }

  if (!response.ok) {
    fail(`Timeline API request failed with HTTP ${response.status}: ${payload.message || payload.error || 'unknown error'}`);
  }
  return payload;
}

function queryTimelineFromDynamo(context, deviceId, options) {
  const end = options.end ? new Date(options.end) : new Date();
  const start = options.start ? new Date(options.start) : new Date(end.getTime() - options.hours * 60 * 60 * 1000);
  const records = queryTimelineRecordsFromDynamo(context, deviceId, start.toISOString(), end.toISOString(), options);

  if (records.length === 0 && !options.allowEmpty) fail(`No data found for device: ${deviceId}`);

  return {
    deviceId,
    start: start.toISOString(),
    end: end.toISOString(),
    count: records.length,
    events: records.map(formatTimelineRecord),
    source: 'dynamodb',
  };
}

function queryTimelineRecordsFromDynamo(context, deviceId, start, end, options) {
  const records = [];
  const readAwsJson = context.awsJson || awsJson;
  const requestedLimit = options.limit || DEFAULT_TIMELINE_LIMIT;
  const pageLimit = Math.min(requestedLimit, options.pageLimit || WATCH_DYNAMO_PAGE_LIMIT);
  const maxRows = Math.min(options.maxRows || requestedLimit, WATCH_DYNAMO_MAX_ROWS);
  let exclusiveStartKey;

  do {
    const args = [
      'dynamodb', 'query',
      '--table-name', context.logEventsTableName,
      '--key-condition-expression', 'deviceId = :deviceId AND eventTime BETWEEN :start AND :end',
      '--expression-attribute-values', JSON.stringify({
        ':deviceId': { S: deviceId },
        ':start': { S: start },
        ':end': { S: end },
      }),
      '--no-scan-index-forward',
      '--limit', String(Math.min(pageLimit, requestedLimit - records.length, maxRows - records.length)),
    ];
    if (exclusiveStartKey) {
      args.push('--exclusive-start-key', JSON.stringify(exclusiveStartKey));
    }

    const page = readAwsJson(context.options, args, {
      operation: 'dynamodb query timeline',
      tableName: context.logEventsTableName,
      deviceId,
      pagination: true,
    });
    records.push(...((page.Items || []).map(unmarshall)));
    exclusiveStartKey = page.LastEvaluatedKey;
  } while (exclusiveStartKey && records.length < requestedLimit && records.length < maxRows);

  return records;
}

function formatTimelineRecord(record) {
  return {
    eventTime: record.eventTime,
    eventName: record.eventName,
    ...(record.eventId && { eventId: record.eventId }),
    ...(record.eventType && { eventType: record.eventType }),
    ...(record.plane && { plane: record.plane }),
    ...(record.severity && { severity: record.severity }),
    ...(record.fwVersion && { fwVersion: record.fwVersion }),
    ...(record.battery !== undefined && { battery: record.battery }),
    ...(record.connectTime !== undefined && { connectTime: record.connectTime }),
    ...(record.resetCount !== undefined && { resetCount: record.resetCount }),
    ...(record.alertCount !== undefined && { alertCount: record.alertCount }),
    ...(record.temperature !== undefined && { temperature: record.temperature }),
    ...(record.occupancy !== undefined && { occupancy: record.occupancy }),
    ...(record.dailyOccupancy !== undefined && { dailyOccupancy: record.dailyOccupancy }),
    ...(record.serialLogLine && { serialLogLine: record.serialLogLine }),
    ...(record.logLine && { logLine: record.logLine }),
    ...(record.s3Key && { s3Key: record.s3Key }),
  };
}

function outputDevices(devices, json) {
  const rows = devices.map(device => ({
    NAME: displayName(device),
    'DEVICE ID': safe(device.deviceId),
    'LAST EVENT': safe(device.lastEventType || device.eventName),
    'LAST SEEN': safeIso(device.lastEventTime),
    FIRMWARE: safe(device.fwVersion),
    'LEDGER UPDATED': safeIso(device.deviceStatusLedgerUpdatedAt),
  }));

  if (json) {
    console.log(JSON.stringify(devices, null, 2));
  } else {
    printTable(rows, ['NAME', 'DEVICE ID', 'LAST EVENT', 'LAST SEEN', 'FIRMWARE', 'LEDGER UPDATED']);
  }
}

function outputDevice(device, json) {
  if (json) {
    console.log(JSON.stringify(device, null, 2));
    return;
  }

  const rows = [
    ['Name', displayName(device)],
    ['Device ID', safe(device.deviceId)],
    ['Project', safe(device.projectId)],
    ['Last event', safe(device.lastEventType)],
    ['Last seen', safeIso(device.lastEventTime)],
    ['Last ingest', safeIso(device.lastIngestTime)],
    ['Firmware', safe(device.fwVersion)],
    ['Ledger updated', safeIso(device.deviceStatusLedgerUpdatedAt)],
    ['Ledger fetched', safeIso(device.deviceStatusLedgerFetchedAt)],
    ['Ledger size bytes', safe(device.deviceStatusLedgerSizeBytes)],
    ['Battery', safe(device.battery)],
    ['Occupancy', safe(device.occupancy)],
    ['Daily occupancy', safe(device.dailyOccupancy)],
    ['Temperature', safe(device.temperature)],
  ];

  const width = Math.max(...rows.map(([label]) => label.length));
  for (const [label, value] of rows) {
    console.log(`${label.padEnd(width)}  ${value}`);
  }
}

function outputTimeline(device, timeline, json) {
  if (json) {
    console.log(JSON.stringify(timeline, null, 2));
    return;
  }

  console.log(`Device: ${displayName(device)} (${device.deviceId})`);
  console.log(`Window: ${safeIso(timeline.start)} to ${safeIso(timeline.end)}`);
  console.log(`Events: ${timeline.count}`);
  console.log('');

  const rows = (timeline.events || []).map(event => ({
    TIME: safeIso(event.eventTime),
    CATEGORY: classifyTimelineEvent(event).category,
    EVENT: safe(event.eventName),
    TYPE: safe(event.eventType),
    PLANE: safe(event.plane),
    FIRMWARE: safe(event.fwVersion),
  }));
  printTable(rows, ['TIME', 'CATEGORY', 'EVENT', 'TYPE', 'PLANE', 'FIRMWARE']);
}

async function startWatch(context, device, options) {
  if (!options.json) {
    for (const line of getWatchBannerLines(device, options)) console.log(line);
  }

  const controller = new AbortController();
  const onSigint = () => controller.abort();
  process.once('SIGINT', onSigint);

  try {
    await runWatchLoop(context, device, options, {
      signal: controller.signal,
      write: line => console.log(line),
      warn: message => console.error(message),
      sleep,
      now: () => new Date(),
    });
  } finally {
    process.removeListener('SIGINT', onSigint);
    if (!options.json) console.log('\nStopped.');
  }
}

function getWatchBannerLines(device, options) {
  const lines = [
    `Watching ${displayName(device)} (${device.deviceId}) ${options.sinceMs > 0 ? `since ${formatDuration(options.sinceMs)}` : 'from now'}`,
  ];
  if (options.sinceMs === 0) lines.push('Use --since <duration> to include recent history.');
  lines.push('Press Ctrl-C to stop.');
  lines.push('');
  return lines;
}

async function runWatchLoop(context, device, options, deps = {}) {
  const state = createWatchState(options, deps.now ? deps.now() : new Date());
  const write = deps.write || (line => console.log(line));
  const warn = deps.warn || (message => console.error(message));
  const sleepFn = deps.sleep || sleep;
  const nowFn = deps.now || (() => new Date());
  const fetchTimelineFn = deps.fetchTimeline || fetchWatchTimeline;
  const loadCurrentStateFn = deps.loadCurrentState || loadDeviceCurrentState;
  const signal = deps.signal;
  let consecutiveFailures = 0;

  while (!signal || !signal.aborted) {
    try {
      const now = nowFn();
      const timeline = await fetchTimelineFn(context, device.deviceId, state, now);
      const currentState = await loadCurrentStateFn(context, device.deviceId);
      const entries = buildWatchEntries(timeline.events || [], currentState, state, options);

      for (const entry of entries) {
        write(formatWatchEntry(entry, options));
      }

      consecutiveFailures = 0;
      await sleepFn(options.intervalSeconds * 1000, signal);
    } catch (err) {
      if (signal && signal.aborted) break;
      consecutiveFailures += 1;
      const transient = isTransientWatchError(err);
      if (!transient) throw err;
      if (consecutiveFailures >= 2) {
        warn(`WARN: watch reconnecting after ${consecutiveFailures} failed polls: ${err.message}`);
      }
      await sleepFn(getWatchBackoffMs(consecutiveFailures), signal);
    }
  }
}

function createWatchState(options, now) {
  const startMs = options.sinceMs > 0 ? now.getTime() - options.sinceMs : now.getTime() - WATCH_CURSOR_LOOKBACK_MS;
  return {
    initialized: false,
    includeInitialTimeline: options.sinceMs > 0,
    cursor: null,
    seenEventIds: new Set(),
    timelineStart: new Date(startMs).toISOString(),
    currentStateSnapshot: null,
  };
}

async function fetchWatchTimeline(context, deviceId, state, now) {
  const start = state.cursor ? state.cursor.eventTime : state.timelineStart;
  const end = now.toISOString();
  const events = [];
  let pageEnd = end;
  const visitedPageEnds = new Set();

  while (true) {
    if (visitedPageEnds.has(pageEnd)) break;
    visitedPageEnds.add(pageEnd);

    const page = await fetchTimelinePage(context, deviceId, {
      start,
      end: pageEnd,
      limit: WATCH_TIMELINE_LIMIT,
    });
    const pageEvents = page.events || [];
    events.push(...pageEvents);

    if (pageEvents.length < WATCH_TIMELINE_LIMIT) break;

    const oldest = [...pageEvents].sort(compareWatchEvents)[0];
    if (!oldest || compareEventToCursor(oldest, state.cursor) <= 0) break;
    pageEnd = oldest.eventTime;
  }

  return { events };
}

async function fetchTimelinePage(context, deviceId, params) {
  if (!context.webhookSecret) {
    return queryTimelineFromDynamo(context, deviceId, {
      start: params.start,
      end: params.end,
      limit: params.limit,
      allowEmpty: true,
    });
  }

  const query = new URLSearchParams({
    start: params.start,
    end: params.end,
    limit: String(params.limit),
  });
  const url = `${context.queryApiBaseUrl}/${encodeURIComponent(deviceId)}/timeline?${query.toString()}`;
  let response;
  try {
    response = await fetch(url, {
      headers: {
        'x-particle-webhook-secret': context.webhookSecret,
        Accept: 'application/json',
      },
    });
  } catch (err) {
    throw new TransientWatchError(`Timeline API unavailable: ${err && err.message ? err.message : String(err)}`);
  }

  const text = await response.text();
  let payload;
  try {
    payload = text ? JSON.parse(text) : {};
  } catch {
    throw new TransientWatchError(`Timeline API returned non-JSON response with HTTP ${response.status}.`);
  }

  if (!response.ok) {
    const message = `Timeline API request failed with HTTP ${response.status}: ${payload.message || payload.error || 'unknown error'}`;
    if (response.status === 429 || response.status >= 500) throw new TransientWatchError(message);
    fail(message);
  }

  return payload;
}

function loadDeviceCurrentState(context, deviceId) {
  const result = awsJson(context.options, [
    'dynamodb', 'get-item',
    '--table-name', context.deviceCurrentStateTableName,
    '--key', JSON.stringify({
      projectId: { S: context.options.projectId },
      deviceId: { S: deviceId },
    }),
  ]);
  return result.Item ? unmarshall(result.Item) : null;
}

function buildWatchEntries(events, currentState, state, options) {
  const entries = [];
  const newEvents = collectNewTimelineEvents(events, state);

  if (!state.initialized) {
    if (state.includeInitialTimeline) {
      for (const event of newEvents) {
        markWatchEventSeen(state, event);
        const entry = watchEntryFromEvent(event, options);
        if (entry && shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
      }
    } else {
      for (const event of newEvents) markWatchEventSeen(state, event);
    }

    for (const entry of initialCurrentStateEntries(currentState)) {
      if (shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
    }

    state.currentStateSnapshot = snapshotCurrentState(currentState);
    state.initialized = true;
    entries.sort((left, right) => left.time.localeCompare(right.time) || left.category.localeCompare(right.category));
    return entries;
  }

  for (const event of newEvents) {
    markWatchEventSeen(state, event);
    const entry = watchEntryFromEvent(event, options);
    if (entry && shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
  }

  for (const entry of detectCurrentStateChanges(currentState, state.currentStateSnapshot)) {
    if (shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
  }
  state.currentStateSnapshot = snapshotCurrentState(currentState);

  entries.sort((left, right) => left.time.localeCompare(right.time) || left.category.localeCompare(right.category));
  return entries;
}

function collectNewTimelineEvents(events, state) {
  return [...events]
    .filter(event => compareEventToCursor(event, state.cursor) > 0 && !state.seenEventIds.has(watchEventId(event)))
    .sort(compareWatchEvents);
}

function markWatchEventSeen(state, event) {
  state.seenEventIds.add(watchEventId(event));
  if (compareEventToCursor(event, state.cursor) > 0) {
    state.cursor = { eventTime: event.eventTime, id: watchEventId(event) };
  }
}

function compareEventToCursor(event, cursor) {
  if (!cursor) return 1;
  const timeCompare = String(event.eventTime || '').localeCompare(cursor.eventTime);
  if (timeCompare !== 0) return timeCompare;
  return watchEventId(event).localeCompare(cursor.id);
}

function compareWatchEvents(left, right) {
  return String(left.eventTime || '').localeCompare(String(right.eventTime || '')) || watchEventId(left).localeCompare(watchEventId(right));
}

function watchEventId(event) {
  return stringValue(event.eventId) || stringValue(event.s3Key) || `${event.eventTime}:${event.eventName}`;
}

function watchEntryFromEvent(event, options) {
  const classification = classifyTimelineEvent(event);

  if (classification.category === 'SERIAL') {
    return {
      time: event.eventTime,
      category: classification.category,
      summary: maybeTruncate(serialLine(event), options),
      event,
    };
  }

  const metrics = compactMetricSummary(event);
  if (metrics) {
    return {
      time: event.eventTime,
      category: classification.category,
      summary: metrics,
      event,
    };
  }

  return {
    time: event.eventTime,
    category: classification.category,
    summary: classification.summary,
    event,
  };
}

function classifyTimelineEvent(event) {
  if (event.eventName === 'status') {
    return { category: 'LIFECYCLE', summary: safe(event.eventType || event.eventName) };
  }

  if (isSerialEvent(event)) {
    return { category: 'SERIAL', summary: serialLine(event) };
  }

  if (event.severity === 'ERROR') {
    return { category: 'ERROR', summary: safe(event.eventType || event.eventName) };
  }

  if (compactMetricSummary(event)) {
    return { category: 'TELEMETRY', summary: compactMetricSummary(event) };
  }

  return { category: 'EVENT', summary: safe(event.eventType || event.eventName) };
}

function isSerialEvent(event) {
  return event.eventName === 'serialLog' || event.eventType === 'serial.log' || event.plane === 'serial';
}

function serialLine(event) {
  return stringValue(event.serialLogLine) || stringValue(event.logLine) || stringValue(event.data) || safe(event.eventName);
}

function compactMetricSummary(event) {
  const fields = [
    ['occupancy', event.occupancy],
    ['dailyOccupancy', event.dailyOccupancy],
    ['battery', event.battery],
    ['temperature', event.temperature],
    ['connectTime', event.connectTime],
    ['resetCount', event.resetCount],
    ['alertCount', event.alertCount],
  ].filter(([, value]) => value !== undefined && value !== null);
  if (fields.length === 0) return '';
  return fields.map(([name, value]) => `${name}=${value}`).join(' ');
}

function detectCurrentStateChanges(currentState, previousSnapshot) {
  const nextSnapshot = snapshotCurrentState(currentState);
  if (!previousSnapshot) return [];

  const entries = [];
  if (nextSnapshot.deviceStatusLedgerUpdatedAt && nextSnapshot.deviceStatusLedgerUpdatedAt !== previousSnapshot.deviceStatusLedgerUpdatedAt) {
    entries.push({
      time: nextSnapshot.deviceStatusLedgerUpdatedAt,
      category: 'RUNTIME',
      summary: 'device-status snapshot updated',
    });
  }
  if (nextSnapshot.deviceDataLedgerUpdatedAt && nextSnapshot.deviceDataLedgerUpdatedAt !== previousSnapshot.deviceDataLedgerUpdatedAt) {
    entries.push({
      time: nextSnapshot.deviceDataLedgerUpdatedAt,
      category: 'DATA',
      summary: 'device-data snapshot updated',
    });
  }
  return entries;
}

function initialCurrentStateEntries(currentState) {
  const snapshot = snapshotCurrentState(currentState);
  const entries = [];
  if (snapshot.deviceStatusLedgerUpdatedAt) {
    entries.push({
      time: snapshot.deviceStatusLedgerUpdatedAt,
      category: 'RUNTIME',
      summary: 'device-status snapshot available',
    });
  }
  if (snapshot.deviceDataLedgerUpdatedAt) {
    entries.push({
      time: snapshot.deviceDataLedgerUpdatedAt,
      category: 'DATA',
      summary: 'device-data snapshot available',
    });
  }
  return entries;
}

function snapshotCurrentState(currentState) {
  return {
    deviceStatusLedgerUpdatedAt: currentState && currentState.deviceStatusLedgerUpdatedAt,
    deviceDataLedgerUpdatedAt: currentState && currentState.deviceDataLedgerUpdatedAt,
    updatedAt: currentState && currentState.updatedAt,
    lastEventTime: currentState && currentState.lastEventTime,
    lastIngestTime: currentState && currentState.lastIngestTime,
  };
}

function shouldIncludeWatchCategory(category, options) {
  if (options.includeTypes && !options.includeTypes.has(category)) return false;
  if (options.excludeTypes && options.excludeTypes.has(category)) return false;
  return true;
}

function formatWatchEntry(entry, options) {
  if (options.json) {
    return JSON.stringify({
      time: entry.time,
      category: entry.category,
      summary: entry.summary,
      ...(entry.event && { event: entry.event }),
    });
  }

  return `${formatLocalTime(entry.time)}  ${entry.category.padEnd(10)} ${entry.summary}`;
}

function maybeTruncate(value, options) {
  const text = safe(value);
  if (options.raw || text.length <= WATCH_LINE_MAX_LENGTH) return text;
  return `${text.slice(0, WATCH_LINE_MAX_LENGTH - 3)}...`;
}

function formatLocalTime(value) {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return safe(value);
  return date.toLocaleTimeString(undefined, {
    hour12: false,
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    fractionalSecondDigits: 3,
  });
}

function isTransientWatchError(err) {
  return err instanceof TransientWatchError;
}

function getWatchBackoffMs(consecutiveFailures) {
  return Math.min(30_000, 1000 * (2 ** Math.min(consecutiveFailures - 1, 5)));
}

function sleep(ms, signal) {
  return new Promise((resolve) => {
    if (signal && signal.aborted) {
      resolve();
      return;
    }
    const timeout = setTimeout(resolve, ms);
    if (signal) {
      signal.addEventListener('abort', () => {
        clearTimeout(timeout);
        resolve();
      }, { once: true });
    }
  });
}

function printTable(rows, columns) {
  if (rows.length === 0) {
    console.log('No rows.');
    return;
  }

  const widths = Object.fromEntries(columns.map(column => [
    column,
    Math.max(column.length, ...rows.map(row => String(row[column] || '-').length)),
  ]));

  console.log(columns.map(column => column.padEnd(widths[column])).join(' | '));
  console.log(columns.map(column => '-'.repeat(widths[column])).join('-|-'));
  for (const row of rows) {
    console.log(columns.map(column => String(row[column] || '-').padEnd(widths[column])).join(' | '));
  }
}

function awsJson(options, args, settings = {}) {
  const awsArgs = [...args, '--output', 'json'];
  if (options.awsProfile) awsArgs.push('--profile', options.awsProfile);
  if (options.awsRegion) awsArgs.push('--region', options.awsRegion);

  const result = spawnSync('aws', awsArgs, { encoding: 'utf8', maxBuffer: 16 * 1024 * 1024 });
  if (result.error && result.error.code === 'ENOENT') fail('AWS CLI was not found. Install/configure awscli before using this tool.');
  if (result.error && result.error.code === 'ENOBUFS') {
    failAwsJson(settings, 'output buffering failed');
  }
  if (result.error) {
    failAwsJson(settings, result.error.message || 'subprocess failed');
  }
  if (result.status !== 0) {
    const stderr = (result.stderr || '').trim();
    if (settings.notFoundMessage && /does not exist|not found|ValidationError/i.test(stderr)) fail(settings.notFoundMessage);
    if (/NoRegion|must specify a region/i.test(stderr)) {
      fail('AWS region is not configured. Set AWS_REGION/AWS_DEFAULT_REGION or pass --region <region>.');
    }
    if (/Unable to locate credentials|could not be found|NoCredentials|ExpiredToken|AccessDenied/i.test(stderr)) {
      fail(`AWS credentials unavailable or unauthorized: ${stderr}`);
    }
    if (settings.operation) {
      failAwsJson(settings, stderr || 'pagination failed');
    }
    fail(`AWS CLI command failed: ${stderr || args.join(' ')}`);
  }

  try {
    return JSON.parse(result.stdout || '{}');
  } catch {
    if (settings.operation) failAwsJson(settings, 'invalid JSON response');
    fail(`AWS CLI returned invalid JSON for: aws ${args.join(' ')}`);
  }
}

function failAwsJson(settings, reason) {
  const details = [
    `operation=${settings.operation || 'aws json'}`,
    ...(settings.tableName ? [`table=${settings.tableName}`] : []),
    ...(settings.deviceId ? [`deviceId=${settings.deviceId}`] : []),
    `reason=${reason}`,
    ...(settings.pagination ? ['pagination=true'] : []),
  ];
  fail(`AWS CLI operation failed (${details.join(', ')})`);
}

function unmarshall(attributeMap) {
  return Object.fromEntries(Object.entries(attributeMap).map(([key, value]) => [key, unmarshallValue(value)]));
}

function unmarshallValue(value) {
  if (value.S !== undefined) return value.S;
  if (value.N !== undefined) return Number(value.N);
  if (value.BOOL !== undefined) return value.BOOL;
  if (value.NULL !== undefined) return null;
  if (value.M !== undefined) return unmarshall(value.M);
  if (value.L !== undefined) return value.L.map(unmarshallValue);
  if (value.SS !== undefined) return value.SS;
  if (value.NS !== undefined) return value.NS.map(Number);
  return undefined;
}

function isDeviceId(value) {
  return DEVICE_ID_PATTERN.test(value);
}

function failAmbiguous(selector, matches) {
  const lines = [`Ambiguous device selector: ${selector}`, 'Matches:'];
  for (const device of matches) {
    lines.push(`  ${displayName(device)}  ${device.deviceId}`);
  }
  throw new OperatorError(lines.join('\n'), 2);
}

function fail(message) {
  throw new OperatorError(message);
}

class OperatorError extends Error {
  constructor(message, exitCode = 1) {
    super(message);
    this.exitCode = exitCode;
  }
}

class TransientWatchError extends Error {}

function displayName(device) {
  return stringValue(device.deviceName) || '<unknown>';
}

function stringValue(value) {
  return typeof value === 'string' && value.trim() ? value.trim() : '';
}

function safe(value) {
  if (value === undefined || value === null || value === '') return '-';
  return String(value);
}

function safeIso(value) {
  return safe(value);
}

function compareIso(left, right) {
  return new Date(left || 0).getTime() - new Date(right || 0).getTime();
}

if (require.main === module) {
  main();
}

module.exports = {
  OperatorError,
  TransientWatchError,
  buildWatchEntries,
  classifyTimelineEvent,
  collectNewTimelineEvents,
  createWatchState,
  detectCurrentStateChanges,
  enrichDeviceNames,
  formatDuration,
  formatWatchEntry,
  getWatchBannerLines,
  isDeviceId,
  loadDeviceInventory,
  parseOptions,
  queryTimelineFromDynamo,
  resolveDeviceSelector,
  runWatchLoop,
  watchEntryFromEvent,
};
