const DEFAULT_STACK_NAME = 'InfraStack';
const DEFAULT_PROJECT_ID = 'generalized-core-counter';
const DEFAULT_FLEET_PRODUCT_ID = '42131';
const LOCAL_SECRETS_RELATIVE_PATH = '.particle-log-monitoring/secrets.env';
const DEFAULT_TIMELINE_HOURS = 24;
const DEFAULT_TIMELINE_LIMIT = 25;
const DEFAULT_FLEET_ACTIVITY_LIMIT = 10;
const DEFAULT_TRANSPORT_ALLOWANCE_SECONDS = 60;
const DEFAULT_WATCH_INTERVAL_SECONDS = 3;
const WATCH_TIMELINE_LIMIT = 200;
const WATCH_DYNAMO_PAGE_LIMIT = 200;
const WATCH_DYNAMO_MAX_ROWS = 2000;
const WATCH_CURSOR_LOOKBACK_MS = 5 * 60 * 1000;
const WATCH_LINE_MAX_LENGTH = 160;
const DEVICE_ID_PATTERN = /^[a-fA-F0-9]{24}$/;
const COMMANDS = new Set(['devices', 'device', 'timeline', 'watch', 'serial', 'fleet']);

async function main() {
  const args = process.argv.slice(2);
  const command = args.shift();

  try {
    if (!command || command === '--help' || command === '-h') {
      printUsage();
      return;
    }

    if (command === 'help') {
      const helpCommand = args[0];
      if (!helpCommand) {
        printUsage();
        return;
      }
      printCommandHelp(helpCommand);
      return;
    }

    if (!COMMANDS.has(command)) {
      fail(`Unknown command: ${command}`);
    }

    if (args.includes('--help') || args.includes('-h')) {
      printCommandHelp(command);
      return;
    }

    const options = parseOptions(args);
    const context = await loadContext(options);

    if (command === 'devices') {
      ensureNoSelector(options.positionals, 'devices');
      const devices = await loadDeviceInventory(context, { productId: options.productId });
      if (devices.length === 0) fail('No devices found in Particle product inventory.');
      outputDevices(devices, options.json);
      return;
    }

    if (command === 'fleet') {
      ensureNoSelector(options.positionals, 'fleet');
      const devices = await loadDeviceInventory(context, { productId: options.productId });
      const summary = buildFleetSummary(devices, {
        productId: options.productId,
        activityLimit: options.activityLimit,
        transportAllowanceSeconds: options.transportAllowanceSeconds,
      });
      outputFleetSummary(summary, options);
      return;
    }

    if (command === 'device') {
      const selector = requireSelector(options.positionals, 'device');
      const devices = await loadDeviceInventory(context, { productId: options.productId });
      const device = resolveDeviceSelector(devices, selector, context);
      outputDevice(device, options.json);
      return;
    }

    if (command === 'timeline') {
      const selector = requireSelector(options.positionals, 'timeline');
      const devices = await loadDeviceInventory(context, { productId: options.productId });
      const device = resolveDeviceSelector(devices, selector, context);
      const timeline = await fetchTimeline(context, device.deviceId, options);
      outputTimeline(device, timeline, options.json);
      return;
    }

    if (command === 'watch') {
      const selector = requireSelector(options.positionals, 'watch');
      const devices = await loadDeviceInventory(context, { productId: options.productId });
      const device = resolveDeviceSelector(devices, selector, context);
      await startWatch(context, device, options);
      return;
    }

    if (command === 'serial') {
      const selector = requireSelector(options.positionals, 'serial');
      validateSerialOptions(options);
      const devices = await loadDeviceInventory(context, { productId: options.productId });
      const device = resolveDeviceSelector(devices, selector, context);
      await startSerial(context, device, options);
      return;
    }

  } catch (err) {
    if (err instanceof OperatorError) {
      console.error(`ERROR: ${err.message}`);
      process.exit(err.exitCode);
    }
    console.error(`ERROR: ${err && err.message ? err.message : String(err)}`);
    process.exit(1);
  }
}

