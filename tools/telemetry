  ];
}

function batterySocOverviewRows(batterySoc) {
  return [
    ['Observed', formatCompactCoverage(batterySoc.observed, batterySoc.inventory)],
    ['Lowest', formatSocPercent(batterySoc.lowest)],
    ['Median', formatSocPercent(batterySoc.median)],
    ['Unknown', batterySoc.unknown],
  ];
}

function formatHorizontalOverview(sections) {
  const rendered = sections.map(renderOverviewSection);
  const widths = rendered.map(section => Math.max(section.title.length, ...section.rows.map(row => row.length)));
  const maxRows = Math.max(...rendered.map(section => section.rows.length));
  const lines = [rendered.map((section, index) => section.title.padEnd(widths[index])).join('   ')];

  for (let rowIndex = 0; rowIndex < maxRows; rowIndex += 1) {
    lines.push(rendered.map((section, index) => (section.rows[rowIndex] || '').padEnd(widths[index])).join('   ').trimEnd());
  }
  return lines;
}

function formatStackedOverview(sections) {
  const lines = [];
  for (const section of sections) {
    if (lines.length > 0) lines.push('');
    lines.push(...formatCountBlock(section.title, section.rows));
  }
  return lines;
}

function renderOverviewSection(section) {
  const labelWidth = Math.max(1, ...section.rows.map(([label]) => String(label).length));
  return {
    title: section.title,
    rows: section.rows.map(([label, value]) => `${String(label).padEnd(labelWidth)}  ${value}`),
  };
}

function terminalWidth(options) {
  if (Number.isInteger(options.terminalWidth)) return options.terminalWidth;
  return process.stdout.columns || 120;
}

function formatDistribution(label, distribution) {
  return formatCountBlock(label, distribution.map(entry => [entry.value, entry.count]));
}

function formatCountBlock(label, entries) {
  const width = Math.max(1, ...entries.map(([name]) => String(name).length));
  return [
    label,
    '-'.repeat(label.length),
    ...entries.map(([name, count]) => `${String(name).padEnd(width)}  ${count}`),
  ];
}

function formatCoverage(count, inventory) {
  if (inventory === 0) return `${count} / 0 (-)`;
  return `${count} / ${inventory} (${formatPercent(count / inventory)})`;
}

function formatCompactCoverage(count, inventory) {
  if (inventory === 0) return `${count} / 0`;
  return `${count} / ${inventory}`;
}

function formatDeviceDataCoverage(coverage, inventory) {
  if (coverage.deviceData === 0) return 'Not Enabled';
  return formatCoverage(coverage.deviceData, inventory);
}

function formatPercent(ratio) {
  const percent = ratio * 100;
  return `${Number.isInteger(percent) ? percent.toFixed(0) : percent.toFixed(1)}%`;
}

function formatSocPercent(value) {
  if (typeof value !== 'number' || !Number.isFinite(value)) return '-';
  return `${Math.round(value)}%`;
}

function buildFleetAttention(devices, coverage, options = {}) {
  const deviceDataEnabled = coverage.deviceData > 0;
  const now = options.now || new Date();
  return devices.map((device) => {
    const observations = [];
    const waitingForTelemetry = device.coverage.productInventory && device.connected === true && !device.coverage.currentState && !device.coverage.runtimeStatus;

    if (waitingForTelemetry) {
      observations.push('Cloud connected');
      observations.push('Waiting for first telemetry');
    } else {
      if (!device.coverage.currentState) observations.push('No Current State');
      if (observations.length > 0 || !device.coverage.runtimeStatus) {
        observations.push(`Last heard ${formatLongRelativeDuration(fleetDeviceLastHeardTime(device), now)} ago`);
      }
      if (!device.coverage.runtimeStatus) observations.push('Runtime status not yet observed');
    }

    if (deviceDataEnabled && !device.coverage.deviceData) observations.push('Device Data not observed');
    if (device.socPercent !== null && device.socObservedAt && isOlderThan(device.socObservedAt, now, 6 * 60 * 60 * 1000)) {
      observations.push(`Last reported SOC ${formatSocPercent(device.socPercent)}`);
      observations.push(`SOC observation is ${formatRelativeDuration(device.socObservedAt, now)} old`);
    }
    if (hasRecentSerialActivityWithOlderParticleLastHeard(device, now)) {
      observations.push(`Recent serial activity; Particle last heard ${formatRelativeDuration(device.lastHeard, now)} ago`);
    }
    if (device.expectationStatus === 'overdue' && device.expectedNextReport) {
      observations.push(`Expected application report ${formatLongRelativeDuration(device.expectedNextReport, now)} ago`);
    }
    return {
      deviceId: device.deviceId,
      deviceName: device.deviceName,
      observations,
    };
  }).filter(entry => entry.observations.length > 0);
}

function formatFleetAttention(attention) {
  const lines = [];
  for (const entry of attention) {
    if (lines.length > 0) lines.push('');
    lines.push(safe(entry.deviceName));
    for (const observation of entry.observations) {
      lines.push(`  - ${observation}`);
    }
  }
  return lines;
}

function buildFleetRecentActivity(devices, options = {}) {
  const limit = options.activityLimit ?? DEFAULT_FLEET_ACTIVITY_LIMIT;
  if (limit === 0) return [];

  return devices.map((device) => {
    const reportedAt = stringValue(device.lastEventTime);
    if (reportedAt) {
      const event = {
        eventTime: reportedAt,
        deviceId: device.deviceId,
        deviceName: device.deviceName,
        eventName: device.metadata?.lastEventName,
        eventType: device.metadata?.lastEventType,
        plane: device.metadata?.lastPlane,
        sourceType: device.metadata?.lastSourceType,
        severity: device.metadata?.lastSeverity,
      };
      const presentation = presentEvent(event);
      if (presentation.kind === 'COLLECTOR') return null;

      return {
        ...presentation,
        source: 'DeviceCurrentState',
        authority: 'EventHistory projection',
        ...(device.lastHeard && { particleLastHeard: device.lastHeard }),
      };
    }

    const cloudTime = stringValue(device.lastHeard);
    if (device.connected === true && cloudTime) {
      return {
        ...presentObservation('EVENT', {
          time: cloudTime,
          deviceId: device.deviceId,
          deviceName: device.deviceName,
          summary: 'Connected to Particle Cloud',
          sourceType: 'particle-product-api',
        }),
        source: 'Particle Product API',
        authority: 'Particle Product API',
      };
    }

    return null;
  }).filter(Boolean)
    .sort((left, right) => compareIso(right.time, left.time) || safe(left.deviceName).localeCompare(safe(right.deviceName)))
    .slice(0, limit);
}

function isSerialActivity(lastEventName, lastEventType, lastPlane) {
  return presentEvent({
    eventName: lastEventName,
    eventType: lastEventType,
    plane: lastPlane,
  }).kind === 'SERIAL';
}

function hasRecentSerialActivityWithOlderParticleLastHeard(device, now) {
  const lastEventName = stringValue(device.metadata?.lastEventName);
  const lastEventType = stringValue(device.metadata?.lastEventType);
  const lastPlane = stringValue(device.metadata?.lastPlane);
  if (!isSerialActivity(lastEventName, lastEventType, lastPlane)) return false;

  const eventTime = new Date(device.lastEventTime || 0).getTime();
  const lastHeardTime = new Date(device.lastHeard || 0).getTime();
  if (!device.lastEventTime || !device.lastHeard || Number.isNaN(eventTime) || Number.isNaN(lastHeardTime)) return false;
  return eventTime > lastHeardTime + 5 * 60 * 1000 && eventTime >= new Date(now).getTime() - 60 * 60 * 1000;
}

function formatRecentActivity(activity, options) {
  return activity.map(entry => `${formatActivityTime(entry.time, options)}  ${safe(entry.kind).padEnd(10)} ${safe(entry.deviceName)} ${entry.summary}`);
}

function formatActivityTime(value, options) {
  if (options.verbose) return safeIso(value);
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return safe(value);
  return date.toLocaleTimeString(undefined, {
    hour12: false,
    hour: '2-digit',
    minute: '2-digit',
  });
}

function fleetDeviceLastHeardTime(device) {
  return device.lastHeard || device.lastEventTime;
}

function formatFleetTime(value, options) {
  if (options.verbose) return safeIso(value);
  return formatRelativeTime(value, options.now || new Date());
}

function formatRelativeTime(value, now) {
  const duration = formatRelativeDuration(value, now);
  return duration === 'unknown' ? safe(value) : `${duration} ago`;
}

function formatRelativeDuration(value, now) {
  const time = new Date(value).getTime();
  const nowTime = new Date(now).getTime();
  if (!value || Number.isNaN(time) || Number.isNaN(nowTime)) return 'unknown';
  const deltaSeconds = Math.max(0, Math.floor((nowTime - time) / 1000));
  if (deltaSeconds < 60) return `${deltaSeconds} sec`;
  const deltaMinutes = Math.floor(deltaSeconds / 60);
  if (deltaMinutes < 60) return `${deltaMinutes} min`;
  const deltaHours = Math.floor(deltaMinutes / 60);
  if (deltaHours < 48) return `${deltaHours} hr`;
  const deltaDays = Math.floor(deltaHours / 24);
  return `${deltaDays} day${deltaDays === 1 ? '' : 's'}`;
}

function formatLongRelativeDuration(value, now) {
  return formatRelativeDuration(value, now)
    .replace(/\bhr\b/g, 'hours')
    .replace(/\bmin\b/g, 'minutes');
}

function isOlderThan(value, now, thresholdMs) {
  const time = new Date(value).getTime();
  const nowTime = new Date(now).getTime();
  if (!value || Number.isNaN(time) || Number.isNaN(nowTime)) return false;
  return nowTime - time >= thresholdMs;
}

function evidenceCell(value, color) {
  return value ? colorText('Y', 'green', color) : colorText('-', 'dim', color);
}

function cloudCell(value, color) {
  if (value === true) return colorText('Online', 'green', color);
  if (value === false) return colorText('Offline', 'red', color);
  return colorText('Unknown', 'dim', color);
}

function runtimeStatusCell(device, color) {
  if (device.coverage.runtimeStatus) return colorText('Observed', 'green', color);
  if (device.coverage.currentState) return colorText('Pending', 'dim', color);
  return colorText('Unknown', 'dim', color);
}

function expectedReportCell(device, now, color) {
  if (!device.expectedNextReport || device.expectationStatus === 'unknown') {
    return colorText('-', 'dim', color);
  }

  const expectedMs = new Date(device.expectedNextReport).getTime();
  const nowMs = new Date(now).getTime();
  if (Number.isNaN(expectedMs) || Number.isNaN(nowMs)) return colorText('-', 'dim', color);
  const deltaMs = expectedMs - nowMs;
  const reference = new Date(nowMs - Math.abs(deltaMs));
  const duration = formatRelativeDuration(reference, new Date(nowMs));
  if (deltaMs < 0) return colorText(`${duration} overdue`, 'red', color);
  return colorText(deltaMs < 1000 ? 'due now' : `in ${duration}`, 'green', color);
}

function shouldUseColor(options) {
  if (options.json) return false;
  if (options.color === true) return true;
  if (options.color === false || process.env.NO_COLOR) return false;
  return Boolean(process.stdout.isTTY);
}

function colorText(value, color, enabled) {
  if (!enabled) return value;
  const codes = {
    green: ['\x1b[32m', '\x1b[39m'],
    red: ['\x1b[31m', '\x1b[39m'],
    dim: ['\x1b[2m', '\x1b[22m'],
  };
  const pair = codes[color];
  return pair ? `${pair[0]}${value}${pair[1]}` : value;
}

function fleetSummaryJson(summary, options) {
  if (options.verbose) return summary;
  return {
    ...summary,
    devices: summary.devices.map(({ metadata, ...device }) => device),
  };
}

function outputTimeline(device, timeline, json) {
  if (json) {
    console.log(JSON.stringify(timeline, null, 2));
    return;
  }

  console.log(`Device: ${displayName(device)} (${device.deviceId})`);
  console.log(`Window: ${safeIso(timeline.start)} to ${safeIso(timeline.end)}`);
  console.log(`Events: ${timeline.count}`);
  console.log('');

  const { rows, columns } = timelinePresentationRows(device, timeline);
  printTable(rows, columns);
}

function timelinePresentationRows(device, timeline) {
  const presentations = (timeline.events || []).map(event => presentEvent(event, {
    deviceId: device.deviceId,
    deviceName: displayName(device),
  }));
  const serialOnly = presentations.length > 0 && presentations.every(item => item.kind === 'SERIAL');

  if (serialOnly) {
    return {
      rows: presentations.map(item => ({ TIME: safeIso(item.time), 'SERIAL LOG': item.summary })),
      columns: ['TIME', 'SERIAL LOG'],
      presentations,
    };
  }

  return {
    rows: presentations.map(item => ({ TIME: safeIso(item.time), KIND: item.kind, SUMMARY: item.summary })),
    columns: ['TIME', 'KIND', 'SUMMARY'],
    presentations,
  };
}

async function startWatch(context, device, options) {
  if (!options.json) {
    for (const line of getWatchBannerLines(device, options)) console.log(line);
  }

  const controller = new AbortController();
  const onSigint = () => controller.abort();
  process.once('SIGINT', onSigint);

  try {
    await runWatchLoop(context, device, options, {
      signal: controller.signal,
      write: line => console.log(line),
      warn: message => console.error(message),
      sleep,
      now: () => new Date(),
    });
  } finally {
    process.removeListener('SIGINT', onSigint);
    if (!options.json) console.log('\nStopped.');
  }
}

async function startSerial(context, device, options) {
  const write = line => console.log(line);
  const warn = message => console.error(message);
  if (!options.json) {
    const collectorNote = options.includeCollector ? ' plus Serial Forwarder lifecycle observations' : '';
    warn(`Source: cloud-forwarded serial output${collectorNote} for ${displayName(device)} (${device.deviceId}); not direct USB/UART capture.`);
  }

  const controller = new AbortController();
  const onSigint = () => controller.abort();
  process.once('SIGINT', onSigint);

  try {
    await runSerialLoop(context, device, options, {
      signal: controller.signal,
      write,
      warn,
      sleep,
      now: () => new Date(),
    });
  } finally {
    process.removeListener('SIGINT', onSigint);
    if (options.follow && !options.json) warn('Stopped.');
  }
}

async function runSerialLoop(context, device, options, deps = {}) {
  validateSerialOptions(options);
  const write = deps.write || (line => console.log(line));
  const warn = deps.warn || (message => console.error(message));
  const sleepFn = deps.sleep || sleep;
  const nowFn = deps.now || (() => new Date());
  const fetchTimelineFn = deps.fetchTimeline || fetchSerialTimeline;
  const signal = deps.signal;
  const initialEnd = options.until ? new Date(options.until) : nowFn();
  const state = createSerialState(options, initialEnd);
  const renderer = createSerialRenderer(options);
  let consecutiveFailures = 0;

  while (!signal || !signal.aborted) {
    try {
      const now = state.initialized ? nowFn() : initialEnd;
      const timeline = await fetchTimelineFn(context, device.deviceId, state, now, options);
      const entries = buildSerialEntries(timeline.events || [], state, options);

      for (const entry of entries) {
        for (const line of renderer.format(entry)) write(line);
      }
      consecutiveFailures = 0;

      if (!options.follow) break;
      await sleepFn(options.intervalSeconds * 1000, signal);
    } catch (err) {
      if (signal && signal.aborted) break;
      consecutiveFailures += 1;
      const transient = isTransientWatchError(err);
      if (!transient) throw err;
      if (consecutiveFailures >= 2) {
        warn(`WARN: serial reconnecting after ${consecutiveFailures} failed polls: ${err.message}`);
      }
      await sleepFn(getWatchBackoffMs(consecutiveFailures), signal);
    }
  }
}

function validateSerialOptions(options) {
  if (!options.follow && !options.sinceMs) fail('serial requires --since unless --follow starts from now.');
}

function createSerialState(options, now) {
  const state = createWatchState(options, now);
  state.includeInitialTimeline = options.sinceMs > 0;
  state.serialRowsEmitted = 0;
  return state;
}

async function fetchSerialTimeline(context, deviceId, state, now, options) {
  return fetchWatchTimeline(context, deviceId, state, now, options.limit || DEFAULT_TIMELINE_LIMIT);
}

function buildSerialEntries(events, state, options) {
  const entries = [];
  const newEvents = collectNewTimelineEvents(events, state);

  for (const event of newEvents) {
    markWatchEventSeen(state, event);
    if (!state.includeInitialTimeline && !state.initialized) continue;
    const entry = watchEntryFromEvent(event, options);
    if (!entry || (entry.kind !== 'SERIAL' && !(options.includeCollector && entry.kind === 'COLLECTOR'))) continue;
    if (options.grep && !entry.summary.includes(options.grep)) continue;
    if (!options.follow && state.serialRowsEmitted >= options.limit) continue;
    entries.push(entry);
    state.serialRowsEmitted += 1;
  }

  state.initialized = true;
  entries.sort((left, right) => String(left.time || '').localeCompare(String(right.time || '')) || watchEventId(left.event).localeCompare(watchEventId(right.event)));
  return entries;
}

function formatSerialEntry(entry, options) {
  if (options.json) {
    return JSON.stringify({
      time: entry.time,
      line: entry.summary,
      source: entry.kind === 'COLLECTOR' ? 'serial-forwarder' : 'cloud-forwarded serial',
      kind: entry.kind,
      severity: entry.severity,
      event: entry.event,
    });
  }

  const kind = options.includeCollector ? `${entry.kind.padEnd(10)} ` : '';
  if (options.verbose) return `${safeIso(entry.time)}  ${kind}${entry.summary}`;
  return `${formatLocalTime(entry.time, options)}  ${kind}${entry.summary}`;
}

function createSerialRenderer(options = {}) {
  let wroteHeader = false;
  let currentDate = null;
  return {
    format(entry) {
      const formatted = formatSerialEntry(entry, options);
      if (options.json || options.verbose) return [formatted];

      const lines = [];
      if (!wroteHeader) {
        lines.push(`Timezone: ${serialTimeZoneLabel(options)}`);
        wroteHeader = true;
      }

      const date = formatLocalDate(entry.time, options);
      if (date && date !== currentDate) {
        lines.push(`--- ${date} ---`);
        currentDate = date;
      }
      lines.push(formatted);
      return lines;
    },
  };
}

function serialTimeZoneLabel(options = {}) {
  return options.timeZone || Intl.DateTimeFormat().resolvedOptions().timeZone || 'local';
}

function formatLocalDate(value, options = {}) {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '';
  return date.toLocaleDateString('en-CA', {
    timeZone: options.timeZone,
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}

function getWatchBannerLines(device, options) {
  const lines = [
    `Watching ${displayName(device)} (${device.deviceId}) ${options.sinceMs > 0 ? `since ${formatDuration(options.sinceMs)}` : 'from now'}`,
    `Timezone: ${serialTimeZoneLabel(options)}`,
  ];
  if (options.sinceMs === 0) lines.push('Use --since <duration> to include recent history.');
  lines.push('Press Ctrl-C to stop.');
  lines.push('');
  return lines;
}

async function runWatchLoop(context, device, options, deps = {}) {
  const state = createWatchState(options, deps.now ? deps.now() : new Date());
  const write = deps.write || (line => console.log(line));
  const warn = deps.warn || (message => console.error(message));
  const sleepFn = deps.sleep || sleep;
  const nowFn = deps.now || (() => new Date());
  const fetchTimelineFn = deps.fetchTimeline || fetchWatchTimeline;
  const loadCurrentStateFn = deps.loadCurrentState || loadDeviceCurrentState;
  const signal = deps.signal;
  let consecutiveFailures = 0;

  while (!signal || !signal.aborted) {
    try {
      const now = nowFn();
      const timeline = await fetchTimelineFn(context, device.deviceId, state, now);
      const currentState = await loadCurrentStateFn(context, device.deviceId);
      const entries = buildWatchEntries(timeline.events || [], currentState, state, options);

      for (const entry of entries) {
        write(formatWatchEntry(entry, options));
      }

      consecutiveFailures = 0;
      await sleepFn(options.intervalSeconds * 1000, signal);
    } catch (err) {
      if (signal && signal.aborted) break;
      consecutiveFailures += 1;
      const transient = isTransientWatchError(err);
      if (!transient) throw err;
      if (consecutiveFailures >= 2) {
        warn(`WARN: watch reconnecting after ${consecutiveFailures} failed polls: ${err.message}`);
      }
      await sleepFn(getWatchBackoffMs(consecutiveFailures), signal);
    }
  }
}

function createWatchState(options, now) {
  const startMs = options.sinceMs > 0 ? now.getTime() - options.sinceMs : now.getTime() - WATCH_CURSOR_LOOKBACK_MS;
  return {
    initialized: false,
    includeInitialTimeline: options.sinceMs > 0,
    cursor: null,
    seenEventIds: new Set(),
    timelineStart: new Date(startMs).toISOString(),
    currentStateSnapshot: null,
  };
}

async function fetchWatchTimeline(context, deviceId, state, now, limit = WATCH_TIMELINE_LIMIT) {
  const start = state.cursor ? state.cursor.eventTime : state.timelineStart;
  const end = now.toISOString();
  const events = [];
  let pageEnd = end;
  const visitedPageEnds = new Set();

  while (true) {
    if (visitedPageEnds.has(pageEnd)) break;
    visitedPageEnds.add(pageEnd);

    const page = await fetchTimelinePage(context, deviceId, {
      start,
      end: pageEnd,
      limit,
    });
    const pageEvents = page.events || [];
    events.push(...pageEvents);

    if (pageEvents.length < limit) break;

    const oldest = [...pageEvents].sort(compareWatchEvents)[0];
    if (!oldest || compareEventToCursor(oldest, state.cursor) <= 0) break;
    pageEnd = oldest.eventTime;
  }

  return { events };
}

async function fetchTimelinePage(context, deviceId, params) {
  if (!context.webhookSecret) {
    return queryTimelineFromDynamo(context, deviceId, {
      start: params.start,
      end: params.end,
      limit: params.limit,
      allowEmpty: true,
    });
  }

  const query = new URLSearchParams({
    start: params.start,
    end: params.end,
    limit: String(params.limit),
  });
  const url = `${context.queryApiBaseUrl}/${encodeURIComponent(deviceId)}/timeline?${query.toString()}`;
  let response;
  try {
    response = await fetch(url, {
      headers: {
        'x-particle-webhook-secret': context.webhookSecret,
        Accept: 'application/json',
      },
    });
  } catch (err) {
    throw new TransientWatchError(`Timeline API unavailable: ${err && err.message ? err.message : String(err)}`);
  }

  const text = await response.text();
  let payload;
  try {
    payload = text ? JSON.parse(text) : {};
  } catch {
    throw new TransientWatchError(`Timeline API returned non-JSON response with HTTP ${response.status}.`);
  }

  if (!response.ok) {
    const message = `Timeline API request failed with HTTP ${response.status}: ${payload.message || payload.error || 'unknown error'}`;
    if (response.status === 429 || response.status >= 500) throw new TransientWatchError(message);
    fail(message);
  }

  return payload;
}

function loadDeviceCurrentState(context, deviceId) {
  const result = awsJson(context.options, [
    'dynamodb', 'get-item',
    '--table-name', context.deviceCurrentStateTableName,
    '--key', JSON.stringify({
      projectId: { S: context.options.projectId },
      deviceId: { S: deviceId },
    }),
  ]);
  return result.Item ? unmarshall(result.Item) : null;
}

function buildWatchEntries(events, currentState, state, options) {
  const entries = [];
  const newEvents = collectNewTimelineEvents(events, state);

  if (!state.initialized) {
    if (state.includeInitialTimeline) {
      for (const event of newEvents) {
        markWatchEventSeen(state, event);
        const entry = watchEntryFromEvent(event, options);
        if (entry && shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
      }
    } else {
      for (const event of newEvents) markWatchEventSeen(state, event);
    }

    for (const entry of initialCurrentStateEntries(currentState)) {
      if (shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
    }

    state.currentStateSnapshot = snapshotCurrentState(currentState);
    state.initialized = true;
    entries.sort((left, right) => left.time.localeCompare(right.time) || left.category.localeCompare(right.category));
    return entries;
  }

  for (const event of newEvents) {
    markWatchEventSeen(state, event);
    const entry = watchEntryFromEvent(event, options);
    if (entry && shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
  }

  for (const entry of detectCurrentStateChanges(currentState, state.currentStateSnapshot)) {
    if (shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
  }
  state.currentStateSnapshot = snapshotCurrentState(currentState);

  entries.sort((left, right) => left.time.localeCompare(right.time) || left.category.localeCompare(right.category));
  return entries;
}

function collectNewTimelineEvents(events, state) {
  return [...events]
    .filter(event => compareEventToCursor(event, state.cursor) > 0 && !state.seenEventIds.has(watchEventId(event)))
    .sort(compareWatchEvents);
}

function markWatchEventSeen(state, event) {
  state.seenEventIds.add(watchEventId(event));
  if (compareEventToCursor(event, state.cursor) > 0) {
    state.cursor = { eventTime: event.eventTime, id: watchEventId(event) };
  }
}

function compareEventToCursor(event, cursor) {
  if (!cursor) return 1;
  const timeCompare = String(event.eventTime || '').localeCompare(cursor.eventTime);
  if (timeCompare !== 0) return timeCompare;
  return watchEventId(event).localeCompare(cursor.id);
}

function compareWatchEvents(left, right) {
  return String(left.eventTime || '').localeCompare(String(right.eventTime || '')) || watchEventId(left).localeCompare(watchEventId(right));
}

function watchEventId(event) {
  return stringValue(event.eventId) || stringValue(event.s3Key) || `${event.eventTime}:${event.eventName}`;
}

function watchEntryFromEvent(event, options) {
  const presentation = presentEvent(event);
  return {
    ...presentation,
    category: presentation.kind,
    summary: maybeTruncate(presentation.summary, options),
    event,
  };
}

function classifyTimelineEvent(event) {
  const presentation = presentEvent(event);
  return {
    category: presentation.kind,
    kind: presentation.kind,
    summary: presentation.summary,
    severity: presentation.severity,
  };
}

function detectCurrentStateChanges(currentState, previousSnapshot) {
  const nextSnapshot = snapshotCurrentState(currentState);
  if (!previousSnapshot) return [];

  const entries = [];
  if (nextSnapshot.deviceStatusLedgerUpdatedAt && nextSnapshot.deviceStatusLedgerUpdatedAt !== previousSnapshot.deviceStatusLedgerUpdatedAt) {
    entries.push(watchObservation('RUNTIME', {
      time: nextSnapshot.deviceStatusLedgerUpdatedAt,
      summary: 'device-status snapshot updated',
    }));
  }
  if (nextSnapshot.deviceDataLedgerUpdatedAt && nextSnapshot.deviceDataLedgerUpdatedAt !== previousSnapshot.deviceDataLedgerUpdatedAt) {
    entries.push(watchObservation('DATA', {
      time: nextSnapshot.deviceDataLedgerUpdatedAt,
      summary: 'device-data snapshot updated',
    }));
  }
  return entries;
}

function initialCurrentStateEntries(currentState) {
  const snapshot = snapshotCurrentState(currentState);
  const entries = [];
  if (snapshot.deviceStatusLedgerUpdatedAt) {
    entries.push(watchObservation('RUNTIME', {
      time: snapshot.deviceStatusLedgerUpdatedAt,
      summary: 'device-status snapshot available',
    }));
  }
  if (snapshot.deviceDataLedgerUpdatedAt) {
    entries.push(watchObservation('DATA', {
      time: snapshot.deviceDataLedgerUpdatedAt,
      summary: 'device-data snapshot available',
    }));
  }
  return entries;
}

function watchObservation(kind, input) {
  const presentation = presentObservation(kind, input);
  return { ...presentation, category: presentation.kind };
}

function snapshotCurrentState(currentState) {
  return {
    deviceStatusLedgerUpdatedAt: currentState && currentState.deviceStatusLedgerUpdatedAt,
    deviceDataLedgerUpdatedAt: currentState && currentState.deviceDataLedgerUpdatedAt,
    updatedAt: currentState && currentState.updatedAt,
    lastEventTime: currentState && currentState.lastEventTime,
    lastIngestTime: currentState && currentState.lastIngestTime,
  };
}

function shouldIncludeWatchCategory(category, options) {
  if (options.includeTypes && !options.includeTypes.has(category)) return false;
  if (options.excludeTypes && options.excludeTypes.has(category)) return false;
  return true;
}

function formatWatchEntry(entry, options) {
  if (options.json) {
    return JSON.stringify({
      time: entry.time,
      category: entry.category,
      kind: entry.kind || entry.category,
      summary: entry.summary,
      severity: entry.severity ?? null,
      sourcePlane: entry.sourcePlane ?? null,
      eventName: entry.eventName ?? null,
      eventType: entry.eventType ?? null,
      sourceType: entry.sourceType ?? null,
      eventId: entry.eventId ?? null,
      s3Key: entry.s3Key ?? null,
      ...(entry.event && { event: entry.event }),
    });
  }

  if (options.serialOnly && entry.kind === 'SERIAL') return formatSerialEntry(entry, options);
  return `${formatLocalTime(entry.time, options)}  ${(entry.kind || entry.category).padEnd(10)} ${entry.summary}`;
}

function maybeTruncate(value, options) {
  const text = safe(value);
  if (options.raw || text.length <= WATCH_LINE_MAX_LENGTH) return text;
  return `${text.slice(0, WATCH_LINE_MAX_LENGTH - 3)}...`;
}

function formatLocalTime(value, options = {}) {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return safe(value);
  return date.toLocaleTimeString(undefined, {
    timeZone: options.timeZone,
    hour12: false,
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    fractionalSecondDigits: 3,
  });
}

function isTransientWatchError(err) {
  return err instanceof TransientWatchError;
}

function getWatchBackoffMs(consecutiveFailures) {
  return Math.min(30_000, 1000 * (2 ** Math.min(consecutiveFailures - 1, 5)));
}

function sleep(ms, signal) {
  return new Promise((resolve) => {
    if (signal && signal.aborted) {
      resolve();
      return;
    }
    const timeout = setTimeout(resolve, ms);
    if (signal) {
      signal.addEventListener('abort', () => {
        clearTimeout(timeout);
        resolve();
      }, { once: true });
    }
  });
}

function printTable(rows, columns) {
  for (const line of formatTable(rows, columns)) console.log(line);
}

function formatTable(rows, columns) {
  if (rows.length === 0) {
    return ['No rows.'];
  }

  const widths = Object.fromEntries(columns.map(column => [
    column,
    Math.max(column.length, ...rows.map(row => visibleLength(String(row[column] || '-')))),
  ]));

  const lines = [];
  lines.push(columns.map(column => column.padEnd(widths[column])).join(' | '));
  lines.push(columns.map(column => '-'.repeat(widths[column])).join('-|-'));
  for (const row of rows) {
    lines.push(columns.map(column => padVisible(String(row[column] || '-'), widths[column])).join(' | '));
  }
  return lines;
}

function padVisible(value, width) {
  return value + ' '.repeat(Math.max(0, width - visibleLength(value)));
}

function visibleLength(value) {
  return stripAnsi(value).length;
}

function stripAnsi(value) {
  return String(value).replace(/\x1b\[[0-9;]*m/g, '');
}

function awsJson(options, args, settings = {}) {
  const awsArgs = [...args, '--output', 'json'];
  if (options.awsProfile) awsArgs.push('--profile', options.awsProfile);
  if (options.awsRegion) awsArgs.push('--region', options.awsRegion);

  const result = spawnSync('aws', awsArgs, { encoding: 'utf8', maxBuffer: 16 * 1024 * 1024 });
  if (result.error && result.error.code === 'ENOENT') fail('AWS CLI was not found. Install/configure awscli before using this tool.');
  if (result.error && result.error.code === 'ENOBUFS') {
    failAwsJson(settings, 'output buffering failed');
  }
  if (result.error) {
    failAwsJson(settings, result.error.message || 'subprocess failed');
  }
  if (result.status !== 0) {
    const stderr = (result.stderr || '').trim();
    if (settings.notFoundMessage && /does not exist|not found|ValidationError/i.test(stderr)) fail(settings.notFoundMessage);
    if (/NoRegion|must specify a region/i.test(stderr)) {
      fail('AWS region is not configured. Set AWS_REGION/AWS_DEFAULT_REGION or pass --region <region>.');
    }
    if (/Unable to locate credentials|could not be found|NoCredentials|ExpiredToken|AccessDenied/i.test(stderr)) {
      fail(`AWS credentials unavailable or unauthorized: ${stderr}`);
    }
    if (settings.operation) {
      failAwsJson(settings, stderr || 'pagination failed');
    }
    fail(`AWS CLI command failed: ${stderr || args.join(' ')}`);
  }

  try {
    return JSON.parse(result.stdout || '{}');
  } catch {
    if (settings.operation) failAwsJson(settings, 'invalid JSON response');
    fail(`AWS CLI returned invalid JSON for: aws ${args.join(' ')}`);
  }
}

function failAwsJson(settings, reason) {
  const details = [
    `operation=${settings.operation || 'aws json'}`,
    ...(settings.tableName ? [`table=${settings.tableName}`] : []),
    ...(settings.deviceId ? [`deviceId=${settings.deviceId}`] : []),
    `reason=${reason}`,
    ...(settings.pagination ? ['pagination=true'] : []),
  ];
  fail(`AWS CLI operation failed (${details.join(', ')})`);
}

function unmarshall(attributeMap) {
  return Object.fromEntries(Object.entries(attributeMap).map(([key, value]) => [key, unmarshallValue(value)]));
}

function unmarshallValue(value) {
  if (value.S !== undefined) return value.S;
  if (value.N !== undefined) return Number(value.N);
  if (value.BOOL !== undefined) return value.BOOL;
  if (value.NULL !== undefined) return null;
  if (value.M !== undefined) return unmarshall(value.M);
  if (value.L !== undefined) return value.L.map(unmarshallValue);
  if (value.SS !== undefined) return value.SS;
  if (value.NS !== undefined) return value.NS.map(Number);
  return undefined;
}

function getNested(value, path) {
  let current = value;
  for (const key of path) {
    if (!current || typeof current !== 'object') return undefined;
    current = current[key];
  }
  return current;
}

function isDeviceId(value) {
  return DEVICE_ID_PATTERN.test(value);
}

function failAmbiguous(selector, matches) {
  const lines = [`Ambiguous device selector: ${selector}`, 'Matches:'];
  for (const device of matches) {
    lines.push(`  ${displayName(device)}  ${device.deviceId}`);
  }
  throw new OperatorError(lines.join('\n'), 2);
}

function fail(message) {
  throw new OperatorError(message);
}

class OperatorError extends Error {
  constructor(message, exitCode = 1) {
    super(message);
    this.exitCode = exitCode;
  }
}

class TransientWatchError extends Error {}

function displayName(device) {
  return resolveCanonicalDeviceName({ device });
}

function resolveCanonicalDeviceName({ device = {}, productDevice = null } = {}) {
  return stringValue(productDevice?.deviceName) ||
    stringValue(getNested(device, ['particle', 'name'])) ||
    stringValue(device.canonicalDeviceName) ||
    stringValue(device.fleetOverrideDeviceName) ||
    stringValue(device.deviceName) ||
    stringValue(productDevice?.deviceId) ||
    stringValue(device.deviceId) ||
    '<unknown>';
}

function stringValue(value) {
  return typeof value === 'string' && value.trim() ? value.trim() : '';
}

function safe(value) {
  if (value === undefined || value === null || value === '') return '-';
  return String(value);
}

function safeIso(value) {
  return safe(value);
}

function compareIso(left, right) {
  return new Date(left || 0).getTime() - new Date(right || 0).getTime();
}

