function buildFleetSummary(devices, options = {}) {
  const now = options.now || new Date();
  const summaryDevices = devices.map(device => buildFleetSummaryDevice(device, {
    ...options,
    now,
  }));
  const inventory = summaryDevices.filter(device => device.coverage.productInventory).length;
  const currentState = summaryDevices.filter(device => device.coverage.currentState).length;
  const runtimeStatus = summaryDevices.filter(device => device.coverage.runtimeStatus).length;
  const deviceData = summaryDevices.filter(device => device.coverage.deviceData).length;
  const coverage = {
    inventory,
    currentState,
    runtimeStatus,
    deviceData,
  };
  const attention = buildFleetAttention(summaryDevices, coverage, options);
  const recentActivity = buildFleetRecentActivity(summaryDevices, options);
  const batterySoc = buildBatterySocOverview(summaryDevices, inventory);

  return {
    schema: 'fleet-summary.v1',
    generatedAt: options.generatedAt || new Date(now).toISOString(),
    productId: String(options.productId || DEFAULT_FLEET_PRODUCT_ID),
    coverage,
    connected: {
      connected: summaryDevices.filter(device => device.connected === true).length,
      disconnected: summaryDevices.filter(device => device.connected === false).length,
      unknown: summaryDevices.filter(device => device.connected === null).length,
    },
    distributions: {
      firmware: buildDistribution(summaryDevices.map(device => device.firmwareVersion)),
      deviceOs: buildDistribution(summaryDevices.map(device => device.deviceOsVersion)),
    },
    batterySoc,
    attention,
    recentActivity,
    devices: summaryDevices,
  };
}

function buildFleetSummaryDevice(device, options = {}) {
  const particle = device.particle || {};
  const runtimeConnectionState = extractRuntimeConnectionState(device);
  const connected = extractParticleConnected(particle, runtimeConnectionState);
  const firmwareVersion = extractFirmwareVersion(device);
  const deviceOsVersion = extractDeviceOsVersion(device);
  const socObservation = extractSocObservation(device);
  const reportingExpectation = buildReportingExpectation(device, options);

  return {
    deviceId: device.deviceId,
    deviceName: displayName(device),
    productId: String(device.productId || particle.product_id || particle.productId || ''),
    connected,
    firmwareVersion,
    deviceOsVersion,
    runtimeConnectionState,
    socPercent: socObservation.socPercent,
    socObservedAt: socObservation.socObservedAt,
    socSource: socObservation.socSource,
    ...reportingExpectation,
    lastEventTime: device.lastEventTime || null,
    lastHeard: stringValue(particle.last_heard) || stringValue(particle.lastHeard) || null,
    coverage: {
      productInventory: device.hasProductInventory === true || Boolean(device.particle),
      currentState: device.hasCurrentState === true || Boolean(device.projectId || device.lastEventTime),
      runtimeStatus: hasRuntimeStatusProjection(device),
      deviceData: hasDeviceDataProjection(device),
    },
    metadata: {
      lastEventName: device.lastEventName || device.eventName || null,
      lastEventType: device.lastEventType || null,
      lastIngestTime: device.lastIngestTime || null,
      lastPlane: device.lastPlane || null,
      lastSourceType: device.lastSourceType || null,
      lastSeverity: device.severity || null,
      networkState: device.networkState || null,
      deviceStatusLedgerUpdatedAt: device.deviceStatusLedgerUpdatedAt || null,
      deviceStatusLedgerFetchedAt: device.deviceStatusLedgerFetchedAt || null,
      productDefaultsLedgerUpdatedAt: device.productDefaultsLedgerUpdatedAt || null,
      productDefaultsLedgerFetchedAt: device.productDefaultsLedgerFetchedAt || null,
      deviceSettingsLedgerUpdatedAt: device.deviceSettingsLedgerUpdatedAt || null,
      deviceSettingsLedgerFetchedAt: device.deviceSettingsLedgerFetchedAt || null,
      currentStateUpdatedAt: device.updatedAt || null,
      particlePlatformId: particle.platform_id ?? particle.platformId ?? null,
      particleLastIpAddress: particle.last_ip_address || particle.lastIpAddress || null,
    },
  };
}

function buildReportingExpectation(device, options = {}) {
  const effectiveConfiguration = overlayConfiguration(
    device.productDefaultsLedgerData,
    device.deviceSettingsLedgerData
  );
  const reportingIntervalSeconds = configurationSeconds(effectiveConfiguration, [
    ['timing', 'reportingIntervalSec'],
    ['reporting', 'intervalSeconds'],
    ['reporting', 'intervalSec'],
  ]) ?? configurationMinutesAsSeconds(effectiveConfiguration, [['reporting', 'intervalMinutes']]);
  const connectionBudgetSeconds = configurationSeconds(effectiveConfiguration, [
    ['timing', 'connectAttemptBudgetSec'],
    ['connection', 'connectAttemptBudgetSec'],
    ['connection', 'budgetSeconds'],
    ['reporting', 'connectionBudgetSeconds'],
  ]);
  const transportAllowanceSeconds = Number.isFinite(options.transportAllowanceSeconds) && options.transportAllowanceSeconds >= 0
    ? options.transportAllowanceSeconds
    : DEFAULT_TRANSPORT_ALLOWANCE_SECONDS;
  const lastApplicationReportAt = stringValue(device.lastApplicationReportAt) ||
    (device.lastPlane === 'telemetry' ? stringValue(device.lastEventTime) : '') ||
    null;
  const lastApplicationReportMs = new Date(lastApplicationReportAt || 0).getTime();

  if (
    !lastApplicationReportAt ||
    Number.isNaN(lastApplicationReportMs) ||
    reportingIntervalSeconds === null ||
    connectionBudgetSeconds === null
  ) {
    return {
      lastApplicationReportAt,
      reportingIntervalSeconds,
      connectionBudgetSeconds,
      transportAllowanceSeconds,
      expectedNextReport: null,
      expectationStatus: 'unknown',
    };
  }

  const expectedNextReport = new Date(lastApplicationReportMs + (
    reportingIntervalSeconds + connectionBudgetSeconds + transportAllowanceSeconds
  ) * 1000).toISOString();
  const nowMs = new Date(options.now || new Date()).getTime();

  return {
    lastApplicationReportAt,
    reportingIntervalSeconds,
    connectionBudgetSeconds,
    transportAllowanceSeconds,
    expectedNextReport,
    expectationStatus: !Number.isNaN(nowMs) && nowMs > new Date(expectedNextReport).getTime()
      ? 'overdue'
      : 'upcoming',
  };
}

function overlayConfiguration(productDefaults, deviceSettings) {
  const defaults = isPlainObject(productDefaults) ? productDefaults : {};
  const overrides = isPlainObject(deviceSettings) ? deviceSettings : {};
  const effective = { ...defaults };

  for (const [key, overrideValue] of Object.entries(overrides)) {
    const defaultValue = effective[key];
    effective[key] = isPlainObject(defaultValue) && isPlainObject(overrideValue)
      ? overlayConfiguration(defaultValue, overrideValue)
      : overrideValue;
  }
  return effective;
}

function isPlainObject(value) {
  return Boolean(value) && typeof value === 'object' && !Array.isArray(value);
}

function configurationSeconds(configuration, paths) {
  for (const path of paths) {
    const value = getNested(configuration, path);
    if (typeof value === 'number' && Number.isFinite(value) && value >= 0) return value;
  }
  return null;
}

function configurationMinutesAsSeconds(configuration, paths) {
  const minutes = configurationSeconds(configuration, paths);
  return minutes === null ? null : minutes * 60;
}

function extractFirmwareVersion(device) {
  return stringValue(device.fwVersion) ||
    stringValue(getNested(device.deviceStatusLedgerData, ['firmware', 'version'])) ||
    stringValue(getNested(device.deviceStatusLedgerData, ['application', 'version'])) ||
    null;
}

function extractDeviceOsVersion(device) {
  const particle = device.particle || {};
  return stringValue(particle.system_firmware_version) ||
    stringValue(particle.systemFirmwareVersion) ||
    stringValue(particle.firmware_version) ||
    stringValue(particle.firmwareVersion) ||
    stringValue(getNested(device.deviceStatusLedgerData, ['system', 'firmwareVersion'])) ||
    stringValue(getNested(device.deviceStatusLedgerData, ['deviceOS', 'version'])) ||
    null;
}

function extractParticleConnected(particle, runtimeConnectionState) {
  if (typeof particle.connected === 'boolean') return particle.connected;
  if (String(runtimeConnectionState || '').toLowerCase() === 'connected') return true;
  if (String(runtimeConnectionState || '').toLowerCase() === 'disconnected') return false;
  return null;
}

function extractRuntimeConnectionState(device) {
  return stringValue(getNested(device.deviceStatusLedgerData, ['connection', 'state'])) || null;
}

function extractSocObservation(device) {
  const ledgerSoc = socValue(getNested(device.deviceStatusLedgerData, ['battery', 'soc']));
  if (ledgerSoc !== null) {
    return {
      socPercent: ledgerSoc,
      socObservedAt: device.deviceStatusLedgerUpdatedAt || null,
      socSource: 'device-status',
    };
  }

  const telemetrySoc = socValue(device.battery);
  if (telemetrySoc !== null) {
    return {
      socPercent: telemetrySoc,
      socObservedAt: device.lastEventTime || null,
      socSource: 'telemetry',
    };
  }

  return { socPercent: null, socObservedAt: null, socSource: null };
}

function socValue(value) {
  if (typeof value === 'number' && Number.isFinite(value) && value >= 0 && value <= 100) return value;
  return null;
}

function hasRuntimeStatusProjection(device) {
  return Boolean(device.deviceStatusLedgerData || device.deviceStatusLedgerUpdatedAt || device.deviceStatusLedgerFetchedAt);
}

function buildBatterySocOverview(devices, inventory) {
  const values = devices
    .map(device => device.socPercent)
    .filter(value => typeof value === 'number' && Number.isFinite(value))
    .sort((left, right) => left - right);

  return {
    observed: values.length,
    inventory,
    unknown: Math.max(0, inventory - values.length),
    lowest: values.length > 0 ? values[0] : null,
    median: values.length > 0 ? median(values) : null,
  };
}

function median(sortedValues) {
  const middle = Math.floor(sortedValues.length / 2);
  if (sortedValues.length % 2 === 1) return sortedValues[middle];
  return (sortedValues[middle - 1] + sortedValues[middle]) / 2;
}

function hasDeviceDataProjection(device) {
  return Boolean(device.deviceDataLedgerData || device.deviceDataLedgerUpdatedAt || device.deviceDataLedgerFetchedAt);
}

function buildDistribution(values) {
  const counts = new Map();
  for (const value of values) {
    const key = stringValue(value) || '<unknown>';
    counts.set(key, (counts.get(key) || 0) + 1);
  }
  return [...counts.entries()]
    .map(([value, count]) => ({ value, count }))
    .sort((left, right) => {
      if (left.value === '<unknown>' && right.value !== '<unknown>') return 1;
      if (right.value === '<unknown>' && left.value !== '<unknown>') return -1;
      return right.count - left.count || left.value.localeCompare(right.value);
    });
}

