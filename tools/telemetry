function buildFleetSummary(devices, options = {}) {
  const summaryDevices = devices.map(buildFleetSummaryDevice);
  const inventory = summaryDevices.filter(device => device.coverage.productInventory).length;
  const currentState = summaryDevices.filter(device => device.coverage.currentState).length;
  const runtimeStatus = summaryDevices.filter(device => device.coverage.runtimeStatus).length;
  const deviceData = summaryDevices.filter(device => device.coverage.deviceData).length;

  return {
    schema: 'fleet-summary.v1',
    generatedAt: options.generatedAt || new Date().toISOString(),
    productId: String(options.productId || DEFAULT_FLEET_PRODUCT_ID),
    coverage: {
      inventory,
      currentState,
      runtimeStatus,
      deviceData,
    },
    connected: {
      connected: summaryDevices.filter(device => device.connected === true).length,
      disconnected: summaryDevices.filter(device => device.connected === false).length,
      unknown: summaryDevices.filter(device => device.connected === null).length,
    },
    distributions: {
      firmware: buildDistribution(summaryDevices.map(device => device.firmwareVersion)),
      deviceOs: buildDistribution(summaryDevices.map(device => device.deviceOsVersion)),
    },
    devices: summaryDevices,
  };
}

function buildFleetSummaryDevice(device) {
  const particle = device.particle || {};
  const runtimeConnectionState = extractRuntimeConnectionState(device);
  const connected = extractParticleConnected(particle, runtimeConnectionState);
  const firmwareVersion = extractFirmwareVersion(device);
  const deviceOsVersion = extractDeviceOsVersion(device);

  return {
    deviceId: device.deviceId,
    deviceName: displayName(device),
    productId: String(device.productId || particle.product_id || particle.productId || ''),
    connected,
    firmwareVersion,
    deviceOsVersion,
    runtimeConnectionState,
    lastEventTime: device.lastEventTime || null,
    lastHeard: stringValue(particle.last_heard) || stringValue(particle.lastHeard) || null,
    coverage: {
      productInventory: device.hasProductInventory === true || Boolean(device.particle),
      currentState: device.hasCurrentState === true || Boolean(device.projectId || device.lastEventTime),
      runtimeStatus: hasRuntimeStatusProjection(device),
      deviceData: hasDeviceDataProjection(device),
    },
    metadata: {
      lastEventType: device.lastEventType || null,
      lastIngestTime: device.lastIngestTime || null,
      lastPlane: device.lastPlane || null,
      networkState: device.networkState || null,
      deviceStatusLedgerUpdatedAt: device.deviceStatusLedgerUpdatedAt || null,
      deviceStatusLedgerFetchedAt: device.deviceStatusLedgerFetchedAt || null,
      currentStateUpdatedAt: device.updatedAt || null,
      particlePlatformId: particle.platform_id ?? particle.platformId ?? null,
      particleLastIpAddress: particle.last_ip_address || particle.lastIpAddress || null,
    },
  };
}

function extractFirmwareVersion(device) {
  return stringValue(device.fwVersion) ||
    stringValue(getNested(device.deviceStatusLedgerData, ['firmware', 'version'])) ||
    stringValue(getNested(device.deviceStatusLedgerData, ['application', 'version'])) ||
    null;
}

function extractDeviceOsVersion(device) {
  const particle = device.particle || {};
  return stringValue(particle.system_firmware_version) ||
    stringValue(particle.systemFirmwareVersion) ||
    stringValue(particle.firmware_version) ||
    stringValue(particle.firmwareVersion) ||
    stringValue(getNested(device.deviceStatusLedgerData, ['system', 'firmwareVersion'])) ||
    stringValue(getNested(device.deviceStatusLedgerData, ['deviceOS', 'version'])) ||
    null;
}

function extractParticleConnected(particle, runtimeConnectionState) {
  if (typeof particle.connected === 'boolean') return particle.connected;
  if (String(runtimeConnectionState || '').toLowerCase() === 'connected') return true;
  if (String(runtimeConnectionState || '').toLowerCase() === 'disconnected') return false;
  return null;
}

function extractRuntimeConnectionState(device) {
  return stringValue(getNested(device.deviceStatusLedgerData, ['connection', 'state'])) || null;
}

function hasRuntimeStatusProjection(device) {
  return Boolean(device.deviceStatusLedgerData || device.deviceStatusLedgerUpdatedAt || device.deviceStatusLedgerFetchedAt);
}

function hasDeviceDataProjection(device) {
  return Boolean(device.deviceDataLedgerData || device.deviceDataLedgerUpdatedAt || device.deviceDataLedgerFetchedAt);
}

function buildDistribution(values) {
  const counts = new Map();
  for (const value of values) {
    const key = stringValue(value) || '<unknown>';
    counts.set(key, (counts.get(key) || 0) + 1);
  }
  return [...counts.entries()]
    .map(([value, count]) => ({ value, count }))
    .sort((left, right) => {
      if (left.value === '<unknown>' && right.value !== '<unknown>') return 1;
      if (right.value === '<unknown>' && left.value !== '<unknown>') return -1;
      return right.count - left.count || left.value.localeCompare(right.value);
    });
}

