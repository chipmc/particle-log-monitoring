async function startWatch(context, device, options) {
  if (!options.json) {
    for (const line of getWatchBannerLines(device, options)) console.log(line);
  }

  const controller = new AbortController();
  const onSigint = () => controller.abort();
  process.once('SIGINT', onSigint);

  try {
    await runWatchLoop(context, device, options, {
      signal: controller.signal,
      write: line => console.log(line),
      warn: message => console.error(message),
      sleep,
      now: () => new Date(),
    });
  } finally {
    process.removeListener('SIGINT', onSigint);
    if (!options.json) console.log('\nStopped.');
  }
}

function getWatchBannerLines(device, options) {
  const lines = [
    `Watching ${displayName(device)} (${device.deviceId}) ${options.sinceMs > 0 ? `since ${formatDuration(options.sinceMs)}` : 'from now'}`,
  ];
  if (options.sinceMs === 0) lines.push('Use --since <duration> to include recent history.');
  lines.push('Press Ctrl-C to stop.');
  lines.push('');
  return lines;
}

async function runWatchLoop(context, device, options, deps = {}) {
  const state = createWatchState(options, deps.now ? deps.now() : new Date());
  const write = deps.write || (line => console.log(line));
  const warn = deps.warn || (message => console.error(message));
  const sleepFn = deps.sleep || sleep;
  const nowFn = deps.now || (() => new Date());
  const fetchTimelineFn = deps.fetchTimeline || fetchWatchTimeline;
  const loadCurrentStateFn = deps.loadCurrentState || loadDeviceCurrentState;
  const signal = deps.signal;
  let consecutiveFailures = 0;

  while (!signal || !signal.aborted) {
    try {
      const now = nowFn();
      const timeline = await fetchTimelineFn(context, device.deviceId, state, now);
      const currentState = await loadCurrentStateFn(context, device.deviceId);
      const entries = buildWatchEntries(timeline.events || [], currentState, state, options);

      for (const entry of entries) {
        write(formatWatchEntry(entry, options));
      }

      consecutiveFailures = 0;
      await sleepFn(options.intervalSeconds * 1000, signal);
    } catch (err) {
      if (signal && signal.aborted) break;
      consecutiveFailures += 1;
      const transient = isTransientWatchError(err);
      if (!transient) throw err;
      if (consecutiveFailures >= 2) {
        warn(`WARN: watch reconnecting after ${consecutiveFailures} failed polls: ${err.message}`);
      }
      await sleepFn(getWatchBackoffMs(consecutiveFailures), signal);
    }
  }
}

function createWatchState(options, now) {
  const startMs = options.sinceMs > 0 ? now.getTime() - options.sinceMs : now.getTime() - WATCH_CURSOR_LOOKBACK_MS;
  return {
    initialized: false,
    includeInitialTimeline: options.sinceMs > 0,
    cursor: null,
    seenEventIds: new Set(),
    timelineStart: new Date(startMs).toISOString(),
    currentStateSnapshot: null,
  };
}

async function fetchWatchTimeline(context, deviceId, state, now) {
  const start = state.cursor ? state.cursor.eventTime : state.timelineStart;
  const end = now.toISOString();
  const events = [];
  let pageEnd = end;
  const visitedPageEnds = new Set();

  while (true) {
    if (visitedPageEnds.has(pageEnd)) break;
    visitedPageEnds.add(pageEnd);

    const page = await fetchTimelinePage(context, deviceId, {
      start,
      end: pageEnd,
      limit: WATCH_TIMELINE_LIMIT,
    });
    const pageEvents = page.events || [];
    events.push(...pageEvents);

    if (pageEvents.length < WATCH_TIMELINE_LIMIT) break;

    const oldest = [...pageEvents].sort(compareWatchEvents)[0];
    if (!oldest || compareEventToCursor(oldest, state.cursor) <= 0) break;
    pageEnd = oldest.eventTime;
  }

  return { events };
}

async function fetchTimelinePage(context, deviceId, params) {
  if (!context.webhookSecret) {
    return queryTimelineFromDynamo(context, deviceId, {
      start: params.start,
      end: params.end,
      limit: params.limit,
      allowEmpty: true,
    });
  }

  const query = new URLSearchParams({
    start: params.start,
    end: params.end,
    limit: String(params.limit),
  });
  const url = `${context.queryApiBaseUrl}/${encodeURIComponent(deviceId)}/timeline?${query.toString()}`;
  let response;
  try {
    response = await fetch(url, {
      headers: {
        'x-particle-webhook-secret': context.webhookSecret,
        Accept: 'application/json',
      },
    });
  } catch (err) {
    throw new TransientWatchError(`Timeline API unavailable: ${err && err.message ? err.message : String(err)}`);
  }

  const text = await response.text();
  let payload;
  try {
    payload = text ? JSON.parse(text) : {};
  } catch {
    throw new TransientWatchError(`Timeline API returned non-JSON response with HTTP ${response.status}.`);
  }

  if (!response.ok) {
    const message = `Timeline API request failed with HTTP ${response.status}: ${payload.message || payload.error || 'unknown error'}`;
    if (response.status === 429 || response.status >= 500) throw new TransientWatchError(message);
    fail(message);
  }

  return payload;
}

function loadDeviceCurrentState(context, deviceId) {
  const result = awsJson(context.options, [
    'dynamodb', 'get-item',
    '--table-name', context.deviceCurrentStateTableName,
    '--key', JSON.stringify({
      projectId: { S: context.options.projectId },
      deviceId: { S: deviceId },
    }),
  ]);
  return result.Item ? unmarshall(result.Item) : null;
}

function buildWatchEntries(events, currentState, state, options) {
  const entries = [];
  const newEvents = collectNewTimelineEvents(events, state);

  if (!state.initialized) {
    if (state.includeInitialTimeline) {
      for (const event of newEvents) {
        markWatchEventSeen(state, event);
        const entry = watchEntryFromEvent(event, options);
        if (entry && shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
      }
    } else {
      for (const event of newEvents) markWatchEventSeen(state, event);
    }

    for (const entry of initialCurrentStateEntries(currentState)) {
      if (shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
    }

    state.currentStateSnapshot = snapshotCurrentState(currentState);
    state.initialized = true;
    entries.sort((left, right) => left.time.localeCompare(right.time) || left.category.localeCompare(right.category));
    return entries;
  }

  for (const event of newEvents) {
    markWatchEventSeen(state, event);
    const entry = watchEntryFromEvent(event, options);
    if (entry && shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
  }

  for (const entry of detectCurrentStateChanges(currentState, state.currentStateSnapshot)) {
    if (shouldIncludeWatchCategory(entry.category, options)) entries.push(entry);
  }
  state.currentStateSnapshot = snapshotCurrentState(currentState);

  entries.sort((left, right) => left.time.localeCompare(right.time) || left.category.localeCompare(right.category));
  return entries;
}

function collectNewTimelineEvents(events, state) {
  return [...events]
    .filter(event => compareEventToCursor(event, state.cursor) > 0 && !state.seenEventIds.has(watchEventId(event)))
    .sort(compareWatchEvents);
}

function markWatchEventSeen(state, event) {
  state.seenEventIds.add(watchEventId(event));
  if (compareEventToCursor(event, state.cursor) > 0) {
    state.cursor = { eventTime: event.eventTime, id: watchEventId(event) };
  }
}

function compareEventToCursor(event, cursor) {
  if (!cursor) return 1;
  const timeCompare = String(event.eventTime || '').localeCompare(cursor.eventTime);
  if (timeCompare !== 0) return timeCompare;
  return watchEventId(event).localeCompare(cursor.id);
}

function compareWatchEvents(left, right) {
  return String(left.eventTime || '').localeCompare(String(right.eventTime || '')) || watchEventId(left).localeCompare(watchEventId(right));
}

function watchEventId(event) {
  return stringValue(event.eventId) || stringValue(event.s3Key) || `${event.eventTime}:${event.eventName}`;
}

function watchEntryFromEvent(event, options) {
  const classification = classifyTimelineEvent(event);

  if (classification.category === 'SERIAL') {
    return {
      time: event.eventTime,
      category: classification.category,
      summary: maybeTruncate(serialLine(event), options),
      event,
    };
  }

  const metrics = compactMetricSummary(event);
  if (metrics) {
    return {
      time: event.eventTime,
      category: classification.category,
      summary: metrics,
      event,
    };
  }

  return {
    time: event.eventTime,
    category: classification.category,
    summary: classification.summary,
    event,
  };
}

function classifyTimelineEvent(event) {
  if (event.eventName === 'status') {
    return { category: 'LIFECYCLE', summary: safe(event.eventType || event.eventName) };
  }

  if (isSerialEvent(event)) {
    return { category: 'SERIAL', summary: serialLine(event) };
  }

  if (event.severity === 'ERROR') {
    return { category: 'ERROR', summary: safe(event.eventType || event.eventName) };
  }

  if (compactMetricSummary(event)) {
    return { category: 'TELEMETRY', summary: compactMetricSummary(event) };
  }

  return { category: 'EVENT', summary: safe(event.eventType || event.eventName) };
}

function isSerialEvent(event) {
  return event.eventName === 'serialLog' || event.eventType === 'serial.log' || event.plane === 'serial';
}

function serialLine(event) {
  return stringValue(event.serialLogLine) || stringValue(event.logLine) || stringValue(event.data) || safe(event.eventName);
}

function compactMetricSummary(event) {
  const fields = [
    ['occupancy', event.occupancy],
    ['dailyOccupancy', event.dailyOccupancy],
    ['battery', event.battery],
    ['temperature', event.temperature],
    ['connectTime', event.connectTime],
    ['resetCount', event.resetCount],
    ['alertCount', event.alertCount],
  ].filter(([, value]) => value !== undefined && value !== null);
  if (fields.length === 0) return '';
  return fields.map(([name, value]) => `${name}=${value}`).join(' ');
}

function detectCurrentStateChanges(currentState, previousSnapshot) {
  const nextSnapshot = snapshotCurrentState(currentState);
  if (!previousSnapshot) return [];

  const entries = [];
  if (nextSnapshot.deviceStatusLedgerUpdatedAt && nextSnapshot.deviceStatusLedgerUpdatedAt !== previousSnapshot.deviceStatusLedgerUpdatedAt) {
    entries.push({
      time: nextSnapshot.deviceStatusLedgerUpdatedAt,
      category: 'RUNTIME',
      summary: 'device-status snapshot updated',
    });
  }
  if (nextSnapshot.deviceDataLedgerUpdatedAt && nextSnapshot.deviceDataLedgerUpdatedAt !== previousSnapshot.deviceDataLedgerUpdatedAt) {
    entries.push({
      time: nextSnapshot.deviceDataLedgerUpdatedAt,
      category: 'DATA',
      summary: 'device-data snapshot updated',
    });
  }
  return entries;
}

function initialCurrentStateEntries(currentState) {
  const snapshot = snapshotCurrentState(currentState);
  const entries = [];
  if (snapshot.deviceStatusLedgerUpdatedAt) {
    entries.push({
      time: snapshot.deviceStatusLedgerUpdatedAt,
      category: 'RUNTIME',
      summary: 'device-status snapshot available',
    });
  }
  if (snapshot.deviceDataLedgerUpdatedAt) {
    entries.push({
      time: snapshot.deviceDataLedgerUpdatedAt,
      category: 'DATA',
      summary: 'device-data snapshot available',
    });
  }
  return entries;
}

function snapshotCurrentState(currentState) {
  return {
    deviceStatusLedgerUpdatedAt: currentState && currentState.deviceStatusLedgerUpdatedAt,
    deviceDataLedgerUpdatedAt: currentState && currentState.deviceDataLedgerUpdatedAt,
    updatedAt: currentState && currentState.updatedAt,
    lastEventTime: currentState && currentState.lastEventTime,
    lastIngestTime: currentState && currentState.lastIngestTime,
  };
}

function shouldIncludeWatchCategory(category, options) {
  if (options.includeTypes && !options.includeTypes.has(category)) return false;
  if (options.excludeTypes && options.excludeTypes.has(category)) return false;
  return true;
}

function formatWatchEntry(entry, options) {
  if (options.json) {
    return JSON.stringify({
      time: entry.time,
      category: entry.category,
      summary: entry.summary,
      ...(entry.event && { event: entry.event }),
    });
  }

  return `${formatLocalTime(entry.time)}  ${entry.category.padEnd(10)} ${entry.summary}`;
}

function maybeTruncate(value, options) {
  const text = safe(value);
  if (options.raw || text.length <= WATCH_LINE_MAX_LENGTH) return text;
  return `${text.slice(0, WATCH_LINE_MAX_LENGTH - 3)}...`;
}

function formatLocalTime(value) {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return safe(value);
  return date.toLocaleTimeString(undefined, {
    hour12: false,
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    fractionalSecondDigits: 3,
  });
}

function isTransientWatchError(err) {
  return err instanceof TransientWatchError;
}

function getWatchBackoffMs(consecutiveFailures) {
  return Math.min(30_000, 1000 * (2 ** Math.min(consecutiveFailures - 1, 5)));
}

function sleep(ms, signal) {
  return new Promise((resolve) => {
    if (signal && signal.aborted) {
      resolve();
      return;
    }
    const timeout = setTimeout(resolve, ms);
    if (signal) {
      signal.addEventListener('abort', () => {
        clearTimeout(timeout);
        resolve();
      }, { once: true });
    }
  });
}

function printTable(rows, columns) {
  if (rows.length === 0) {
    console.log('No rows.');
    return;
  }

  const widths = Object.fromEntries(columns.map(column => [
    column,
    Math.max(column.length, ...rows.map(row => String(row[column] || '-').length)),
  ]));

  console.log(columns.map(column => column.padEnd(widths[column])).join(' | '));
  console.log(columns.map(column => '-'.repeat(widths[column])).join('-|-'));
  for (const row of rows) {
    console.log(columns.map(column => String(row[column] || '-').padEnd(widths[column])).join(' | '));
  }
}

function awsJson(options, args, settings = {}) {
  const awsArgs = [...args, '--output', 'json'];
  if (options.awsProfile) awsArgs.push('--profile', options.awsProfile);
  if (options.awsRegion) awsArgs.push('--region', options.awsRegion);

  const result = spawnSync('aws', awsArgs, { encoding: 'utf8', maxBuffer: 16 * 1024 * 1024 });
  if (result.error && result.error.code === 'ENOENT') fail('AWS CLI was not found. Install/configure awscli before using this tool.');
  if (result.error && result.error.code === 'ENOBUFS') {
    failAwsJson(settings, 'output buffering failed');
  }
  if (result.error) {
    failAwsJson(settings, result.error.message || 'subprocess failed');
  }
  if (result.status !== 0) {
    const stderr = (result.stderr || '').trim();
    if (settings.notFoundMessage && /does not exist|not found|ValidationError/i.test(stderr)) fail(settings.notFoundMessage);
    if (/NoRegion|must specify a region/i.test(stderr)) {
      fail('AWS region is not configured. Set AWS_REGION/AWS_DEFAULT_REGION or pass --region <region>.');
    }
    if (/Unable to locate credentials|could not be found|NoCredentials|ExpiredToken|AccessDenied/i.test(stderr)) {
      fail(`AWS credentials unavailable or unauthorized: ${stderr}`);
    }
    if (settings.operation) {
      failAwsJson(settings, stderr || 'pagination failed');
    }
    fail(`AWS CLI command failed: ${stderr || args.join(' ')}`);
  }

  try {
    return JSON.parse(result.stdout || '{}');
  } catch {
    if (settings.operation) failAwsJson(settings, 'invalid JSON response');
    fail(`AWS CLI returned invalid JSON for: aws ${args.join(' ')}`);
  }
}

function failAwsJson(settings, reason) {
  const details = [
    `operation=${settings.operation || 'aws json'}`,
    ...(settings.tableName ? [`table=${settings.tableName}`] : []),
    ...(settings.deviceId ? [`deviceId=${settings.deviceId}`] : []),
    `reason=${reason}`,
    ...(settings.pagination ? ['pagination=true'] : []),
  ];
  fail(`AWS CLI operation failed (${details.join(', ')})`);
}

function unmarshall(attributeMap) {
  return Object.fromEntries(Object.entries(attributeMap).map(([key, value]) => [key, unmarshallValue(value)]));
}

function unmarshallValue(value) {
  if (value.S !== undefined) return value.S;
  if (value.N !== undefined) return Number(value.N);
  if (value.BOOL !== undefined) return value.BOOL;
  if (value.NULL !== undefined) return null;
  if (value.M !== undefined) return unmarshall(value.M);
  if (value.L !== undefined) return value.L.map(unmarshallValue);
  if (value.SS !== undefined) return value.SS;
  if (value.NS !== undefined) return value.NS.map(Number);
  return undefined;
}

function getNested(value, path) {
  let current = value;
  for (const key of path) {
    if (!current || typeof current !== 'object') return undefined;
    current = current[key];
  }
  return current;
}

function isDeviceId(value) {
  return DEVICE_ID_PATTERN.test(value);
}

function failAmbiguous(selector, matches) {
  const lines = [`Ambiguous device selector: ${selector}`, 'Matches:'];
  for (const device of matches) {
    lines.push(`  ${displayName(device)}  ${device.deviceId}`);
  }
  throw new OperatorError(lines.join('\n'), 2);
}

function fail(message) {
  throw new OperatorError(message);
}

class OperatorError extends Error {
  constructor(message, exitCode = 1) {
    super(message);
    this.exitCode = exitCode;
  }
}

class TransientWatchError extends Error {}

function displayName(device) {
  return stringValue(device.deviceName) || '<unknown>';
}

function stringValue(value) {
  return typeof value === 'string' && value.trim() ? value.trim() : '';
}

function safe(value) {
  if (value === undefined || value === null || value === '') return '-';
  return String(value);
}

function safeIso(value) {
  return safe(value);
}

function compareIso(left, right) {
  return new Date(left || 0).getTime() - new Date(right || 0).getTime();
}

